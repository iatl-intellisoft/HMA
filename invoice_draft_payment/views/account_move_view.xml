<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="account_move_buttons_from" model="ir.ui.view">
            <field name="name">account.move.button.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <div name="button_box" position="inside">
                   <button name="button_open_payments" type="object"
                            class="oe_stat_button" icon="fa-bars"
                           invisible="payments_count == 0">
                        <field name="payments_count"/>
                        <span invisible="payments_count &gt; 1">Payments</span>
                        <span invisible="payments_count &gt;= 1">Payments</span>
                    </button>
                </div>

            </field>
        </record>

    </data>
</odoo>
