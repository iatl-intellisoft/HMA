<odoo>
  <data>

        <!-- ── Sale order: per-line warehouse and source location ─────────── -->
        <record id="view_order_form_inherit_multi_warehouse" model="ir.ui.view">
            <field name="name">sale.order.form</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook/page/field/list/field[@name='product_uom_qty']" position="before">
                    <field name="warehouse_id"
                      optional="show"
                      context="{'sale_line_product_id': product_id}"
                      readonly="parent.state not in ('draft', 'sent')"
                      force_save="1"/>
                    <field name="location_id"
                      optional="show"
                      options="{'no_create': True}"
                      readonly="parent.state not in ('draft', 'sent')"/>
                </xpath>
            </field>
        </record>

        <!-- ── Stock picking: allow all locations on internal transfers ───── -->
        <!--
            The StockLocation._search override normally restricts internal
            locations to the user's assigned warehouse.  For internal transfers
            the user must be able to pick any source/destination, so we pass
            show_all_locations=True when the picking type is internal.
            The restriction on WHICH pickings are visible is kept by
            StockPicking._search (source OR destination in user's warehouse).
        -->
        <record id="view_picking_form_inherit_internal_locations" model="ir.ui.view">
            <field name="name">stock.picking.form.internal.locations</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <field name="location_id" groups="stock.group_stock_multi_locations" position="attributes">
                    <attribute name="context">{'show_all_locations': picking_type_code == 'internal'}</attribute>
                </field>
                <field name="location_dest_id" groups="stock.group_stock_multi_locations" position="attributes">
                    <attribute name="context">{'show_all_locations': picking_type_code == 'internal'}</attribute>
                </field>
            </field>
        </record>

        <!-- ── Stock location: Stop Selling flag ─────────────────────────── -->
        <record id="view_location_form_stop_selling" model="ir.ui.view">
            <field name="name">stock.location.form.stop.selling</field>
            <field name="model">stock.location</field>
            <field name="inherit_id" ref="stock.view_location_form"/>
            <field name="arch" type="xml">
                <field name="replenish_location" position="after">
                    <field name="stop_selling"
                           invisible="usage not in ('internal', 'transit')"
                           string="Stop Selling"/>
                </field>
            </field>
        </record>

  </data>
</odoo>
