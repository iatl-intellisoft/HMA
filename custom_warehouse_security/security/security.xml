<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
 
        <record id="group_warehouse_keeper" model="res.groups">
            <field name="name">أمين المخزن (صلاحية مقيدة بالمخزن)</field>
            <field name="category_id" ref="base.module_category_inventory_inventory"/>
            <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]"/>
        </record>
 
        <record id="rule_picking_warehouse_keeper" model="ir.rule">
            <field name="name">أمين المخزن: عمليات مخازنه فقط (مع مراعاة وجهة التحويل الداخلي)</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="domain_force">
                ['|',
                    ('picking_type_id.warehouse_id', 'in', user.employee_id.warehouse_name_ids.ids),
                    '&amp;',
                        ('picking_type_id.code', '=', 'internal'),
                        ('location_dest_id.warehouse_id', 'in', user.employee_id.warehouse_name_ids.ids)
                ]
            </field>
            <field name="groups" eval="[(4, ref('group_warehouse_keeper'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
