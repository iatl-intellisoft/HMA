<odoo>
    <record id="view_sale_top_products_wizard_form" model="ir.ui.view">
        <field name="name">sale.top.products.wizard.form</field>
        <field name="model">sale.top.products.wizard</field>
        <field name="arch" type="xml">
            <form string="تقرير أكثر المنتجات مبيعًا">
                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <footer>
                    <button name="action_print_report" string="طباعة PDF"
                            type="object" class="btn-primary"/>
                    <button string="إلغاء" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_open_sale_top_products_wizard" model="ir.actions.act_window">
        <field name="name">تقرير أكثر المنتجات مبيعًا</field>
        <field name="res_model">sale.top.products.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_sale_top_products_report"
              name="أكثر المنتجات مبيعًا"
	      parent="sale.menu_sale_report"
              action="action_open_sale_top_products_wizard"
              sequence="100"/>
</odoo>
