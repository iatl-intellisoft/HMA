<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_hr_attendance_detail_view" model="ir.actions.act_window">
        <field name="name">Attendance Details</field>
        <field name="res_model">hr.attendance</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'create': False, 'delete': False, 'edit': False}</field>
        <field name="domain">[('id', 'in', context.get('attendance_ids'))]</field>
    </record>

    <record id="hr_employee_view_form_inherit_hikvision" model="ir.ui.view">
        <field name="name">hr.employee.view.form.inherit.hikvision</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Daily Attendance" groups="hr.group_hr_user,hr.group_hr_manager">
                    <group>
                        <field name="attendance_date"/>
                        <field name="total_attendance_hours" widget="float_time"/>
                    </group>
                    <group string="Attendances on Selected Date">
                        <field name="daily_attendance_ids">
                            <list string="Attendance Records (Selected Date)">
                                <field name="check_in"/>
                                <field name="check_out"/>
                                <field name="hik_worked_hours" widget="float_time"/>
                            </list>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
