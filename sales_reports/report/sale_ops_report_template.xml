<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="ops_report_template">
        <t t-call="web.html_container">

            <!--
                docs[0] = sale.ops.report.wizard record
                All picking data is read from the wizard's picking_ids Many2many,
                which is populated by action_print_pdf before calling report_action.
                No client-side data round-trip needed.
            -->
            <t t-set="wizard" t-value="docs[0]"/>
            <t t-set="o"      t-value="wizard"/>
            <t t-set="orders" t-value="wizard._get_ops_report_order_groups()"/>

            <t t-call="web.external_layout">
                <div class="page">

                    <!-- ── Report title + period ─────────────────────────── -->
                    <div class="text-center mb-4">
                        <h3 class="fw-bold">Operation Report</h3>
                        <p t-if="wizard.date_from or wizard.date_to" class="text-muted mb-0">
                            <t t-if="wizard.date_from and wizard.date_to">
                                Period: <span t-field="wizard.date_from"/> to <span t-field="wizard.date_to"/>
                            </t>
                            <t t-elif="wizard.date_from">
                                From: <span t-field="wizard.date_from"/>
                            </t>
                            <t t-else="">
                                Until: <span t-field="wizard.date_to"/>
                            </t>
                        </p>
                    </div>

                    <t t-if="not wizard.picking_ids">
                        <p class="text-center text-muted">No deliveries found for the selected period.</p>
                    </t>

                    <!-- ── One block per customer / sale order ───────────── -->
                    <t t-foreach="orders" t-as="order">
                        <t t-call="sales_reports.ops_report_order_block"/>
                    </t>

                </div>
            </t><!-- /web.external_layout -->

        </t>
    </template>

    <!-- ── One order block: meta header, then Near table, then Far table ──── -->
    <template id="ops_report_order_block">

        <!-- ── Meta header for this order (customer / SO / shipping info) ── -->
        <table class="table table-sm table-bordered mb-2"
               style="table-layout:fixed;width:100%;">
            <colgroup>
                <col style="width:18%"/>
                <col style="width:32%"/>
                <col style="width:20%"/>
                <col style="width:30%"/>
            </colgroup>
            <tbody>
                <tr>
                    <td class="fw-bold bg-light">Customer Name</td>
                    <td t-out="order['partner_name']"/>
                    <td class="fw-bold bg-light">Shipping Office</td>
                    <td t-out="order['shipping_office']"/>
                </tr>
                <tr>
                    <td class="fw-bold bg-light">SO Ref</td>
                    <td t-out="order['so_name']"/>
                    <td class="fw-bold bg-light">Shipping Office No</td>
                    <td t-out="order['shipping_office_no']"/>
                </tr>
                <tr>
                    <td class="fw-bold bg-light">Shipping Destination</td>
                    <td colspan="3" t-out="order['shipping_destination']"/>
                </tr>
            </tbody>
        </table>

        <!-- ── Near-warehouse deliveries for this order ──────────────────── -->
        <t t-if="order['near_pickings']">
            <h5 class="fw-bold mt-1 mb-2">Near Warehouses</h5>
            <t t-set="pickings" t-value="order['near_pickings']"/>
            <t t-call="sales_reports.ops_report_pickings_table"/>
        </t>

        <!-- ── Far-warehouse deliveries for this order ───────────────────── -->
        <t t-if="order['far_pickings']">
            <h5 class="fw-bold mt-3 mb-2">Far Warehouses</h5>
            <t t-set="pickings" t-value="order['far_pickings']"/>
            <t t-call="sales_reports.ops_report_pickings_table"/>
        </t>

        <div class="mb-4"/>

    </template>

    <!-- ── Reusable products table for a given recordset of pickings ───────── -->
    <template id="ops_report_pickings_table">
        <table class="table table-sm table-bordered mb-2"
               style="table-layout:fixed;width:100%;">
            <colgroup>
                <col style="width:30%"/>
                <col style="width:12%"/>
                <col style="width:12%"/>
                <col style="width:26%"/>
                <col style="width:20%"/>
            </colgroup>
            <thead>
                <tr class="table-secondary">
                    <th>Product</th>
                    <th class="text-end">Demand</th>
                    <th class="text-end">Quantity</th>
                    <th>Stock Location</th>
                    <th>Delivery Note Ref</th>
                </tr>
            </thead>
            <tbody>
                <t t-foreach="pickings" t-as="picking">
                    <t t-foreach="picking.move_ids.filtered(lambda m: m.state == 'done' and m.product_id)" t-as="move">
                        <tr>
                            <td t-out="move.product_id.display_name or ''"/>
                            <td class="text-end">
                                <t t-out="'%.2f' % (move.sale_line_id.product_uom_qty if move.sale_line_id else move.product_uom_qty)"/>
                            </td>
                            <td class="text-end">
                                <t t-out="'%.2f' % move.quantity"/>
                            </td>
                            <td t-out="picking.location_id.display_name or ''"/>
                            <td t-out="picking.name"/>
                        </tr>
                    </t>
                </t>
            </tbody>
        </table>
    </template>

</odoo>
