        </record>
        <record id="action_performance_excel_report" model="ir.actions.act_window"> 
            <field name="name">performance Report</field>
            <field name="res_model">performance.report</field>
            <field name="target">new</field>
            <field name="view_id" ref="performance_report_form_view"/>
