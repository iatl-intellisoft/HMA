<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <template id="report_payment_request">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <div>
                            <h2 style='text-align: center;' t-if="o.is_need_clearance == True">Custody Request</h2>
                            <h2 style='text-align: center;' t-if="o.is_need_clearance != True">Payment Request</h2>
                            <br/>
                            <h3>Payment
                                <span t-field="o.name"/>
                            </h3>
                            <table class="table" style="border: 2px solid black">
                                <tbody>

                                    <tr t-if="o.partner_id">
                                        <td>
                                            <strong>Partner</strong>
                                        </td>
                                        <td>
                                            <span t-esc="o.partner_id.name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Employee</strong>
                                        </td>
                                        <td>
                                            <span t-esc="o.employee_id.name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Department</strong>
                                        </td>
                                        <td>
                                            <span t-esc="o.department_id.name"/>
                                        </td>

                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Currency</strong>
                                        </td>
                                        <td>
                                            <span t-esc="o.currency_id.name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Date</strong>
                                        </td>
                                        <td>
                                            <span t-esc="o.date"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Company</strong>
                                        </td>
                                        <td>
                                            <span t-esc="o.company_id.name"/>
                                        </td>
                                    </tr>

                                    <div t-if="o.is_need_clearance">


                                        <tr>
                                            <td>
                                                <strong>Clearance Date</strong>
                                            </td>
                                            <td>
                                                <span t-esc="o.clearance_days"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <strong>Amount</strong>
                                            </td>
                                            <td>
                                                <span t-esc="o.amount"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <strong>Balance</strong>
                                            </td>
                                            <td>
                                                <span t-esc="o.balance"/>
                                            </td>
                                        </tr>
                                    </div>
                                </tbody>
                            </table>


                            <div t-if="len(o.move_line_ids) &gt; 0">
                                <h3>Lines</h3>
                                <br/>
                                <table class="table table-bordered mt32">
                                    <thead>
                                        <tr>
                                            <th style="border: 2px solid black">
                                                <strong>Date</strong>
                                            </th>
                                            <th style="border: 2px solid black">
                                                <strong>Journal Entry</strong>
                                            </th>
                                            <th style="border: 2px solid black">
                                                <strong>Account</strong>
                                            </th>

                                            <th style="border: 2px solid black">
                                                <strong>Partner</strong>
                                            </th>

                                            <th style="border: 2px solid black">
                                                <strong>Label</strong>
                                            </th>

                                            <th style="border: 2px solid black">
                                                <strong>Matching</strong>
                                            </th>
                                            <th style="border: 2px solid black">
                                                <strong>Debit</strong>
                                            </th>
                                            <th style="border: 2px solid black">
                                                <strong>Credit</strong>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="o.move_line_ids" t-as="move_lines_id">
                                            <td style="border: 2px solid black">
                                                <span t-esc="move_lines_id.date"/>
                                            </td>
                                            <td style="border: 2px solid black">
                                                <span t-esc="move_lines_id.move_id.name"/>
                                            </td>
                                            <td style="border: 2px solid black">
                                                <span t-esc="move_lines_id.account_id.name"/>
                                            </td>
                                            <td style="border: 2px solid black">
                                                <span t-esc="move_lines_id.partner_id.name"/>
                                            </td>
                                            <td style="border: 2px solid black">
                                                <span t-esc="move_lines_id.name"/>
                                            </td>
                                            <td style="border: 2px solid black">
                                                <span t-esc="move_lines_id.matching_number"/>
                                            </td>

                                            <td style="border: 2px solid black">
                                                <span t-esc="move_lines_id.credit"/>
                                            </td>

                                            <td style="border: 2px solid black">
                                                <span t-esc="move_lines_id.debit"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="border: 2px solid black"></td>
                                            <td style="border: 2px solid black"></td>
                                            <td style="border: 2px solid black"></td>
                                            <td style="border: 2px solid black"></td>
                                            <td style="border: 2px solid black"></td>
                                            <td style="border: 2px solid black">
                                                <strong>Total</strong>
                                            </td>
                                            <td style="border: 2px solid black">
                                                <span t-esc="sum(o.move_line_ids.mapped('debit'))"/>

                                            </td>
                                            <td style="border: 2px solid black">
                                                <span t-esc="sum(o.move_line_ids.mapped('credit'))"/>

                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                            <div t-if="len(o.line_ids) &gt; 0">
                                <h3>Lines</h3>
                                <br/>
                                <table class="table table-bordered mt32">
                                    <thead>
                                        <tr>
                                            <th style="border: 2px solid black">
                                                <strong>Product</strong>
                                            </th>
                                            <th style="border: 2px solid black">
                                                <strong>Label</strong>
                                            </th>
                                            <th style="border: 2px solid black">
                                                <strong>Account</strong>
                                            </th>

                                            <th style="border: 2px solid black">
                                                <strong>Analytic Account</strong>
                                            </th>

                                            <th style="border: 2px solid black">
                                                <strong>Quantity</strong>
                                            </th>

                                            <th style="border: 2px solid black">
                                                <strong>Unit Price</strong>
                                            </th>
                                            <th style="border: 2px solid black">
                                                <strong>Subtotal</strong>
                                            </th>

                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="o.line_ids" t-as="line_id">
                                            <td style="border: 2px solid black">
                                                <span t-esc="line_id.product_id.name"/>
                                            </td>
                                            <td style="border: 2px solid black">
                                                <span t-esc="line_id.name"/>
                                            </td>
                                            <td style="border: 2px solid black">
                                                <span t-esc="line_id.expense_account_id.name"/>
                                            </td>
                                            <td style="border: 2px solid black">
                                                <span t-esc="line_id.analytic_account_id.name"/>
                                            </td>
                                            <td style="border: 2px solid black">
                                                <span t-esc="line_id.quantity"/>
                                            </td>
                                            <td style="border: 2px solid black">
                                                <span t-esc="line_id.price_unit"/>
                                            </td>

                                            <td style="border: 2px solid black">
                                                <span t-esc="line_id.price_subtotal"/>
                                            </td>


                                        </tr>
                                        <tr>
                                            <td style="border: 2px solid black"/>
                                            <td style="border: 2px solid black"/>
                                            <td style="border: 2px solid black"/>
                                            <td style="border: 2px solid black"/>
                                            <td style="border: 2px solid black"/>
                                            <td style="border: 2px solid black">
                                                <strong>Tax</strong>
                                            </td>

                                            <td style="border: 2px solid black">
                                                <span t-esc="o.amount_tax"/>

                                            </td>
                                        </tr>
                                    <tr>
                                            <td style="border: 2px solid black"/>
                                            <td style="border: 2px solid black"/>
                                            <td style="border: 2px solid black"/>
                                            <td style="border: 2px solid black"/>
                                            <td style="border: 2px solid black"/>
                                            <td style="border: 2px solid black">
                                                <strong>Total</strong>
                                            </td>

                                            <td style="border: 2px solid black">
                                                <span t-esc="o.total_amount"/>

                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>

        <record id="action_report_payment_request" model="ir.actions.report">
            <field name="name">Payment Request</field>
            <field name="model">payment.request</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">payment_request.report_payment_request</field>
            <field name="binding_model_id" ref="payment_request.model_payment_request"/>
        </record>
    </data>
</odoo>