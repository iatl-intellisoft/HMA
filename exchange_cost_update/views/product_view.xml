<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="viewss_product_exchange_tree" model="ir.ui.view">
        <field name="name">product.form.exchange.tree</field>
        <field name="model">product.exchange</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="old_exchange_rate"/>
                <field name="new_exchange_rate"/>
                <field name="profit_margin"/>
                <field name="exchange_change_percent" readonly="1"/>
            </list>
        </field>
    </record>

    <record id="viewss_product_form_exchange" model="ir.ui.view">
        <field name="name">product.form.exchange</field>
        <field name="model">product.exchange</field>
        <field name="arch" type="xml">
            <form>    
                <header>            
                    <button name="action_apply_exchange_update"
                            type="object"
                            string="Apply New Cost and Price"
                            class="btn-primary" invisible="state != 'draft'"/>      
                    <field name="state" widget="statusbar"/> 
                </header> 
                <sheet> 
                    <group>
                        <field name="date"/> 
                        <field name="old_exchange_rate"/>
                        <field name="new_exchange_rate"/> 
                        <field name="profit_margin"/>
                        <field name="exchange_change_percent" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_product_form_exchange" model="ir.actions.act_window">
        <field name="name">product.exchange</field>
        <field name="res_model">product.exchange</field>
        <field name="view_mode">list,form</field>
    </record>

   <menuitem id="menu_product_form_exchange"
          name="Product Exchange"
          parent="stock.menu_product_in_config_stock"
          action="action_product_form_exchange"/>

</odoo>
