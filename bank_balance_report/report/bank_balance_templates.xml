<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_bank_balance_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="wizard_doc">
                <t t-call="web.internal_layout">
                    <div class="page" dir="rtl" style="text-align: right;">

                        <h2 class="text-center">تقرير أرصدة الحسابات البنكية</h2>
                        <h4 class="text-center text-muted">
                            من <span t-esc="date_from"/> إلى <span t-esc="date_to"/>
                        </h4>

                        <table class="table table-bordered table-sm" style="margin-top: 20px;">
                            <thead>
                                <tr style="background-color:#D9E1F2;">
                                    <th>البنك</th>
                                    <th class="text-center">الرصيد الافتتاحي</th>
                                    <th class="text-center">المقبوضات</th>
                                    <th class="text-center">المدفوعات</th>
                                    <th class="text-center">الرصيد الختامي</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="report_data" t-as="line">
                                    <tr>
                                        <td>
                                            <strong t-esc="line['journal'].name"/>
                                        </td>
                                        <td class="text-center">
                                            <span t-esc="'{:,.2f}'.format(line['opening_balance'])"/>
                                        </td>
                                        <td class="text-center">
                                            <span t-esc="'{:,.2f}'.format(line['debit'])"/>
                                        </td>
                                        <td class="text-center">
                                            <span t-esc="'{:,.2f}'.format(line['credit'])"/>
                                        </td>
                                        <td class="text-center">
                                            <strong t-esc="'{:,.2f}'.format(line['closing_balance'])"/>
                                        </td>
                                    </tr>

                                    <t t-if="show_details and line['details']">
                                        <tr>
                                            <td colspan="5" style="padding:0;">
                                                <table class="table table-sm table-bordered" style="margin-bottom:15px;">
                                                    <thead>
                                                        <tr style="background-color:#EDEDED;">
                                                            <th>التاريخ</th>
                                                            <th>رقم القيد</th>
                                                            <th>البيان</th>
                                                            <th class="text-center">مدين</th>
                                                            <th class="text-center">دائن</th>
                                                            <th class="text-center">الرصيد</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <t t-foreach="line['details']" t-as="d">
                                                            <tr>
                                                                <td><span t-esc="d['date']"/></td>
                                                                <td><span t-esc="d['move_name']"/></td>
                                                                <td><span t-esc="d['label']"/></td>
                                                                <td class="text-center">
                                                                    <span t-esc="'{:,.2f}'.format(d['debit'])"/>
                                                                </td>
                                                                <td class="text-center">
                                                                    <span t-esc="'{:,.2f}'.format(d['credit'])"/>
                                                                </td>
                                                                <td class="text-center">
                                                                    <span t-esc="'{:,.2f}'.format(d['balance'])"/>
                                                                </td>
                                                            </tr>
                                                        </t>
                                                    </tbody>
                                                </table>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background-color:#F2F2F2; font-weight:bold;">
                                    <td>الإجمالي</td>
                                    <td class="text-center">
                                        <span t-esc="'{:,.2f}'.format(grand_total['opening'])"/>
                                    </td>
                                    <td class="text-center">
                                        <span t-esc="'{:,.2f}'.format(grand_total['debit'])"/>
                                    </td>
                                    <td class="text-center">
                                        <span t-esc="'{:,.2f}'.format(grand_total['credit'])"/>
                                    </td>
                                    <td class="text-center">
                                        <span t-esc="'{:,.2f}'.format(grand_total['closing'])"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
