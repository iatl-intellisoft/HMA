<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Security Category -->
    <record id="module_category_payment_split" model="ir.module.category">
        <field name="name">Payment Split Access</field>
        <field name="sequence">100</field>
    </record>

    <!-- Single group: Payment Split Manager -->
    <record id="group_payment_split_manager" model="res.groups">
        <field name="name">Payment Split Manager</field>
        <field name="category_id" ref="module_category_payment_split"/>
        <field name="comment">
            Grants access to the four split payment menus:
            Customer Cash, Customer Bank, Vendor Cash, Vendor Bank.
        </field>
        <!-- Automatically includes Accounting / Accountant -->
        <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
    </record>

</odoo>
