<odoo>

    <!-- إضافة الحقل في سطر الفاتورة -->
    <record id="view_move_line_tree_tax_base" model="ir.ui.view">
        <field name="name">account.move.line.tree.tax.base</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
             
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='price_unit']" position="after">
                <field name="tax_base_amount"/>
            </xpath>

        </field>
    </record>


    <!-- إضافة الحقل في الفورم (لو فتحت السطر) -->
    <record id="view_move_line_form_tax_base" model="ir.ui.view">
        <field name="name">account.move.line.form.tax.base</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='invoice_line_ids']/form//field[@name='price_unit']" position="after">
                <field name="tax_base_amount"/>
            </xpath>

        </field>
    </record>

</odoo>