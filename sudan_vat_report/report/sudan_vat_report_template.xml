<?xml version="1.0" encoding="utf-8"?>
<odoo>
<!--
╔══════════════════════════════════════════════════════════════════════════╗
║  Sudan VAT Monthly Declaration Report Template - Form 3                  ║
║  الإقرار الشهري للضريبة على القيمة المضافة - أنموذج رقم (٣)            ║
╚══════════════════════════════════════════════════════════════════════════╝
-->
<template id="report_sudan_vat_template">
 
                <main class="page" >  

 <head>  
                <style>                 
                    @font-face {
                        font-family: 'Cairo-Bold';
                        src: url(/insurance_reports_custom/static/src/fonts/Cairo-VariableFont_slnt,wght.ttf);
                    }
                    body, table, div, span {
                        font-family: 'Cairo-Bold' !important;
                    }
                    td {
                        text-align :right;
                    }
                    img{
                        border: none !important;
                        box-shadow: none !important;
                        outlie: none !important;
                    }  
                </style> 
            </head> 
        <t t-call="web.html_container"> 
<t t-foreach="docs" t-as="o">

<div class="page" style="font-family: 'Noto Naskh Arabic', 'Traditional Arabic', 'Arial', sans-serif; direction: rtl; font-size: 10pt;">

    <!-- ══════════════════════════════════════════════
         PAGE 1 - HEADER + TAXPAYER INFO
    ══════════════════════════════════════════════ -->
    <style>
        .vat-border { border: 2px solid #333; }
        .vat-table  { width: 100%; border-collapse: collapse; margin-bottom: 6px; }
        .vat-table th, .vat-table td {
            border: 1px solid #555;
            padding: 4px 6px;
            text-align: right;
        }
        .vat-table th { background: #d0d0d0; font-weight: bold; font-size: 14pt; }
        .vat-table .num-cell { text-align: center; min-width: 90px; }
        .header-box { text-align: center; padding: 8px; }
        .form-label { font-weight: bold; color: #333; }
        .section-header {
            background: #b0b0b0;
            font-weight: bold;
            text-align: center;
            padding: 4px;
            border: 1px solid #555;
            font-size: 14pt;
        }
        .row-label { font-weight: bold; min-width: 140px; }
        .zebra-odd  { background: #f5f5f5; }
        .zebra-even { background: #ffffff; }
        .total-row  { background: #c8c8c8; font-weight: bold; }
        .page-footer { text-align: center; font-size: 10pt; color: #555; margin-top: 10px; }
        .info-table { width: 100%; border-collapse: collapse; margin-bottom: 8px; }
        .info-table td { border: 1px solid #555; padding: 4px 6px; min-height: 22px; }
        .info-label { background: #d0d0d0; font-weight: bold; width: 130px; }
        .outer-box  { border: 2px solid #333; padding: 10px; }
    </style>

    <!-- ─── OUTER BORDER BOX ─────────────────────────── -->
    <div class="outer-box">

        <!-- FORM NUMBER top-right -->
        <div style="text-align: left; font-size: 10pt; font-weight: bold; margin-bottom: 4px;">
            أنموذج رقم (٣)
        </div>

        <!-- HEADER -->
        <div class="header-box">
            <div style="font-size: 14pt; font-weight: bold;">جمهورية السـودان</div>
            <div style="font-size: 13pt; font-weight: bold;">ديـوان الضـرائب</div>
            <div style="font-size: 13pt; font-weight: bold;">الضريبة على القيمة المضافة</div>
            <div style="font-size: 16pt; font-weight: bold; text-decoration: underline; margin-top: 4px;">VAT</div>
            <div style="font-size: 20pt; font-weight: bold; margin-top: 6px;">الإقرار الشهري</div>
        </div>

        <!-- PERIOD ROW -->
        <table class="vat-table" style="margin-top: 10px;">
            <tr>
                <th style="width:25%;">الإقرار عن</th>
                <th style="width:25%;">الشهر</th>
                <th style="width:25%;">السنة</th>
                <th style="width:25%;"></th>
            </tr>
            <tr>
                <td class="num-cell">
                    <t t-esc="o.declaration_number or ''"/>
                </td>
                <td class="num-cell">
                    <t t-esc="dict([('1','يناير'),('2','فبراير'),('3','مارس'),('4','أبريل'),('5','مايو'),('6','يونيو'),('7','يوليو'),('8','أغسطس'),('9','سبتمبر'),('10','أكتوبر'),('11','نوفمبر'),('12','ديسمبر')]).get(o.month, o.month)"/>
                </td>
                <td class="num-cell"><t t-esc="o.year"/></td>
                <td style="font-size:8pt; color:#555;">
                    طبقاً للمادة (١٠) البند (١) من قانون الضريبة على القيمة المضافة لسنة ٢٠٠١م المعدل
                </td>
            </tr>
        </table>

        <!-- TAXPAYER INFORMATION TABLE -->
        <table class="info-table" style="margin-top: 10px;">
            <tr>
                <td class="info-label">اسم المكلف</td>
                <td colspan="3"><t t-esc="o.taxpayer_name or ''"/></td>
            </tr>
            <tr>
                <td class="info-label">الاسم التجاري</td>
                <td colspan="3"><t t-esc="o.trade_name or ''"/></td>
            </tr>
            <tr>
                <td class="info-label">رقم التسجيل / الرقم التعريفي</td>
                <td colspan="3"><t t-esc="o.tax_registration_number or ''"/></td>
            </tr>
            <tr>
                <td class="info-label">طبيعة النشاط</td>
                <td colspan="3"><t t-esc="o.activity_type or ''"/></td>
            </tr>
            <tr>
                <td class="info-label">الكيان القانوني</td>
                <td colspan="3"><t t-esc="o.legal_entity or ''"/></td>
            </tr>
            <tr>
                <td class="info-label">العنـوان</td>
                <td colspan="3"><t t-esc="o.address or ''"/></td>
            </tr>
            <tr>
                <td class="info-label">الولاية</td>
                <td><t t-esc="o.state_province or ''"/></td>
                <td class="info-label">المحلية</td>
                <td><t t-esc="o.locality or ''"/></td>
            </tr>
            <tr>
                <td class="info-label">الوحدة الإدارية</td>
                <td><t t-esc="o.admin_unit or ''"/></td>
                <td class="info-label">الحي</td>
                <td><t t-esc="o.neighborhood or ''"/></td>
            </tr>
            <tr>
                <td class="info-label">الفريع</td>
                <td><t t-esc="o.block or ''"/></td>
                <td class="info-label">الحارة</td>
                <td><t t-esc="o.quarter or ''"/></td>
            </tr>
            <tr>
                <td class="info-label">السوق</td>
                <td><t t-esc="o.market or ''"/></td>
                <td class="info-label">الشارع</td>
                <td><t t-esc="o.street or ''"/></td>
            </tr>
            <tr>
                <td class="info-label">الطابق</td>
                <td><t t-esc="o.floor or ''"/></td>
                <td class="info-label">المبنى</td>
                <td><t t-esc="o.building or ''"/></td>
            </tr>
            <tr>
                <td class="info-label">الهواتف</td>
                <td><t t-esc="o.phone or ''"/></td>
                <td class="info-label">الجوال</td>
                <td><t t-esc="o.mobile or ''"/></td>
            </tr>
            <tr>
                <td class="info-label">البريد الإلكتروني</td>
                <td><t t-esc="o.email or ''"/></td>
                <td class="info-label">المكتب المختص</td>
                <td><t t-esc="o.specific_office or ''"/></td>
            </tr>
        </table>

        <div class="page-footer">
            الإقرار الشهري للضريبة على القيمة المضافة / ١ - ٤
        </div>

    </div><!-- end outer-box page 1 -->

    <!-- ══════════════════════════════════════════════
         PAGE BREAK → PAGE 2  (General Instructions)
    ══════════════════════════════════════════════ -->
    <div style="page-break-before: always;"></div>

    <div class="outer-box">
        <div class="section-header" style="font-size: 12pt; margin-bottom: 8px;">
            إرشـادات عامـة
        </div>

        <div style="line-height: 2; text-align: justify; padding: 6px;">

            <p>
                <b>أ/١</b>
                يجب على المكلف التعامل بموجب الفاتورة الضريبية و<b>مسك</b> السجلات والدفاتر المحاسبية
                المنتظمة مع توخي الدقة والإدلاء بالمعلومات الصحيحة عند ملء الإقرار.
            </p>

            <p>
                <b>أ/٢</b>
                على المكلف تقديم الإقرار الضريبي في تاريخ أقصاه الخامس عشر من الشهر التالي لشهر
                المحاسبة حتى إذا لم يكن قد حقق بيعاً أو أدى خدمات أو أعمال خاضعة في خلال شهر المحاسبة.
            </p>

            <p>
                <b>أ/٣</b>
                إذا لم يلتزم المكلف بتقديم الإقرار في المواعيد المحددة أو أغفل تقديم الإقرار أو أدلى
                بمعلومات غير صحيحة يكون للأمين الهام الحق في تقدير الضريبة عن فترة المحاسبة
                بالإضافة إلى تطبيق الجزاءات أو العقوبات المنصوص عليها في القانون.
            </p>

            <div class="section-header" style="margin: 10px 0 6px 0;">المبيعـات: /٤</div>
            <p>&#x25C6; تُدرج كافة البيانات الخاصة بالمبيعات والضريبة المحصلة عنها.</p>
            <p>
                &#x25C6; يدخل في حكم البيع إستعمال السلعة أو الإستفادة من الخدمة أو العمل في أغراض
                خاصة أو شخصية أو التصرف فيها بأي من التصرفات القانونية.
            </p>

            <div class="section-header" style="margin: 10px 0 6px 0;">المشتـريات: /٥</div>
            <p>&#x25C6; تُدرج كافة بيانات المشتريات والمصروفات الخاصة بها والضريبة المدفوعة عنها.</p>
            <p>
                &#x25C6; المشتريات والمصروفات (المدخلات) التي تُستخدم في منتجات خاضعة وبعضها معفاة
                تُخصم بنسبة إجمالي <b>المبيعات الخاضعة إلى إجمالي المبيعات الكلية (الخاضعة + المعفاة)</b>.
            </p>
            <p>
                تتم المحاسبة عن السلع المحلية الخاصة وفقاً للأسس المحددة بالقرارات الوزارية أو
                الإدارية على النحو التالي:
            </p>
            <p style="margin-right: 20px;">
                &#x25C6; السلع أو الخدمات المحددة الوعاء على أساس نسبة مئوية من المبلغ الكلي
                (الطباعة، الزيوت المحلية، الذبيح...).
                <br/>
                <b>مقدار الضريبة = المبلغ الكلي × النسبة المئوية × سعر الضريبة</b>
            </p>
            <p style="margin-right: 20px;">
                &#x25C6; السلع المحددة مبلغ الضريبة عن الوحدة الواحدة منها (الذهب / جرام).
                <br/>
                <b>مقدار الضريبة = الكميات المباعة × مبلغ الضريبة عن الوحدة الواحدة</b>
            </p>

            <p>
                <b>الرصيد الدائن المرحل للشهر التالي أو المدين واجب السداد =</b>
                جملة الضريبة المحصلة عن المبيعات خلال شهر + رصيد الضريبة الدائن المرحل
                عن الشهر السابق.
            </p>

            <p>
                <b>أ/٨</b>
                ملء البيانات في الخانات الغير مظللة فقط مع توضيح نوع العملة.
            </p>
        </div>

        <div class="page-footer">
            الإقرار الشهري للضريبة على القيمة المضافة / ٢ - ٤
        </div>
    </div>

    <!-- ══════════════════════════════════════════════
         PAGE BREAK → PAGE 3 (Data Tables)
    ══════════════════════════════════════════════ -->
    <div style="page-break-before: always;"></div>

    <div class="outer-box">

        <!-- MAIN DATA TABLE -->
        <table class="vat-table">
            <!-- Column Headers -->
            <thead>
                <tr>
                    <th style="width:26%; text-align:right;">البيـان (١)</th>
                    <th style="width:16%;" class="num-cell">المبلغ الكلي (٢)</th>
                    <th style="width:10%;" class="num-cell">(٣) أساس التحاسب / نسبة / مبلغ / كمية</th>
                    <th style="width:10%;" class="num-cell">نسبة الضريبة (٤)</th>
                    <th style="width:14%;" class="num-cell">مقدار الضريبة (٥)</th>
                    <th style="width:14%;" class="num-cell">جملة الضريبة (٦)</th>
                </tr>
            </thead>
            <tbody>
                <!-- ── SALES / REVENUES ───────────────── -->
                <tr>
                    <td colspan="6" class="section-header">المبيعـات (الإيـرادات)</td>
                </tr>

                <!-- Row 1 -->
                <tr class="zebra-odd">
                    <td class="row-label">/١ السلع والخدمات والأعمال الخاصة</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.sales_local_total"/></td>
                    <td class="num-cell"></td>
                    <td class="num-cell">%١٧</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.sales_local_tax_amount"/></td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.sales_local_tax_total"/></td>
                </tr>

                <!-- Row 2 -->
                <tr class="zebra-even">
                    <td class="row-label">/٢ الاتصالات</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.sales_telecom_total"/></td>
                    <td class="num-cell"></td>
                    <td class="num-cell">%٣٠</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.sales_telecom_tax_amount"/></td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.sales_telecom_tax_total"/></td>
                </tr>

                <!-- Row 3 -->
                <tr class="zebra-odd">
                    <td class="row-label">/٣ الأصول الثابتة الخاصة</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.sales_assets_total"/></td>
                    <td class="num-cell"></td>
                    <td class="num-cell">%١٧</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.sales_assets_tax_amount"/></td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.sales_assets_tax_total"/></td>
                </tr>

                <!-- Row 4 (special - unit/quantity based) -->
                <tr class="zebra-even">
                    <td class="row-label">/٤ السلع والخدمات والأعمال الخاصة</td>
                    <td class="num-cell"></td>
                    <td colspan="2" style="text-align:center; font-size:8pt;">
                        <div>أساس التحاسب</div>
                        <div>نسبة / مبلغ | مبلغ / كمية</div>
                        <div>وعاء الضريبة</div>
                        <div><t t-esc="'%.2f' % o.sales_special_tax_amount_unit"/></div>
                    </td>
                    <td class="num-cell"></td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.sales_special_tax_total"/></td>
                </tr>

                <!-- Row 5 - Exempt -->
                <tr class="zebra-odd">
                    <td class="row-label">/٥ السلع والخدمات المعفاة</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.sales_exempt_total"/></td>
                    <td class="num-cell" colspan="2" style="text-align:center; color:#666;">إعفـاء</td>
                    <td class="num-cell">-</td>
                    <td class="num-cell">-</td>
                </tr>

                <!-- Row 6 - Exports -->
                <tr class="zebra-even">
                    <td class="row-label">/٦ سلع وخدمات الصادر</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.sales_export_total"/></td>
                    <td class="num-cell" colspan="2" style="text-align:center; color:#666;">صفـر</td>
                    <td class="num-cell">-</td>
                    <td class="num-cell">-</td>
                </tr>

                <!-- Total Sales Tax -->
                <tr class="total-row">
                    <td colspan="5" style="text-align:right; font-weight:bold;">
                        إجمالي الضريبة المحصلة عن الشهر
                    </td>
                    <td class="num-cell" style="font-size:11pt;">
                        <t t-esc="'%.2f' % o.total_sales_tax"/>
                    </td>
                </tr>

                <!-- ── PURCHASES ──────────────────────── -->
                <tr>
                    <td colspan="6" class="section-header">المشـتريات</td>
                </tr>
                <tr>
                    <td colspan="6" style="background:#e0e0e0; font-weight:bold; padding:3px 6px;">
                        المشتريات الخاضعة
                    </td>
                </tr>

                <!-- Row 7 - Imported -->
                <tr class="zebra-odd">
                    <td class="row-label">/٧ المستوردة</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.purchase_import_total"/></td>
                    <td class="num-cell"></td>
                    <td class="num-cell">%١٧</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.purchase_import_tax_amount"/></td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.purchase_import_tax_total"/></td>
                </tr>

                <!-- Row 8 - Local -->
                <tr class="zebra-even">
                    <td class="row-label">/٨ المحلية</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.purchase_local_total"/></td>
                    <td class="num-cell"></td>
                    <td class="num-cell">%١٧</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.purchase_local_tax_amount"/></td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.purchase_local_tax_total"/></td>
                </tr>

                <!-- Row 9 - Fixed Assets -->
                <tr class="zebra-odd">
                    <td class="row-label">/٩ الأصول الثابتة</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.purchase_assets_total"/></td>
                    <td class="num-cell"></td>
                    <td class="num-cell">%١٧</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.purchase_assets_tax_amount"/></td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.purchase_assets_tax_total"/></td>
                </tr>

                <!-- Row 10 - Special local goods -->
                <tr class="zebra-even">
                    <td class="row-label">/١٠ السلع والخدمات والأعمال الخاصة</td>
                    <td class="num-cell"></td>
                    <td colspan="2" style="text-align:center; font-size:8pt;">
                        <div>أساس التحاسب</div>
                        <div>نسبة / مبلغ | مبلغ / كمية</div>
                        <div>وعاء الضريبة</div>
                        <div><t t-esc="'%.2f' % o.purchase_special_tax_amount_unit"/></div>
                    </td>
                    <td class="num-cell"></td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.purchase_special_tax_total"/></td>
                </tr>

                <!-- ── EXPENSES / SERVICES ────────────── -->
                <tr>
                    <td colspan="6" style="background:#e0e0e0; font-weight:bold; padding:3px 6px;">
                        الخدمات والمصروفات الخاضعة
                    </td>
                </tr>

                <!-- Row 11 - Telecom expenses -->
                <tr class="zebra-odd">
                    <td class="row-label">/١١ الاتصالات</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.expense_telecom_total"/></td>
                    <td class="num-cell"></td>
                    <td class="num-cell">%٣٠</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.expense_telecom_tax_amount"/></td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.expense_telecom_tax_total"/></td>
                </tr>

                <!-- Row 12 - Other expenses -->
                <tr class="zebra-even">
                    <td class="row-label">/١٢ أخـرى</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.expense_other_total"/></td>
                    <td class="num-cell"></td>
                    <td class="num-cell">%١٧</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.expense_other_tax_amount"/></td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.expense_other_tax_total"/></td>
                </tr>

                <!-- Row 13 - Imported exempt -->
                <tr class="zebra-odd">
                    <td class="row-label">/١٣ المستوردة المعفاة</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.expense_import_exempt_total"/></td>
                    <td class="num-cell" colspan="2" style="text-align:center; color:#666;">إعفـاء</td>
                    <td class="num-cell">-</td>
                    <td class="num-cell">-</td>
                </tr>

                <!-- Row 14 - Local exempt -->
                <tr class="zebra-even">
                    <td class="row-label">/١٤ المحلية المعفاة</td>
                    <td class="num-cell"><t t-esc="'%.2f' % o.expense_local_exempt_total"/></td>
                    <td class="num-cell" colspan="2" style="text-align:center; color:#666;">إعفـاء</td>
                    <td class="num-cell">-</td>
                    <td class="num-cell">-</td>
                </tr>

                <!-- Total Purchases Tax Paid -->
                <tr class="total-row">
                    <td colspan="5" style="text-align:right; font-weight:bold;">
                        إجمالي الضريبة المدفوعة عن الشهر
                    </td>
                    <td class="num-cell" style="font-size:11pt;">
                        <t t-esc="'%.2f' % o.total_purchase_tax_paid"/>
                    </td>
                </tr>

                <!-- NET TAX FOR MONTH -->
                <tr style="background: #a0a0a0; font-weight:bold;">
                    <td colspan="5" style="text-align:right;">
                        الضريبة عن الشهر (دائن / مدين)
                    </td>
                    <td class="num-cell" style="font-size:11pt;">
