<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sale_report_wizard_form" model="ir.ui.view">
        <field name="name">sale.report.wizard.form</field>
        <field name="model">sale.report.wizard</field>
        <field name="arch" type="xml">
            <form string="تقرير مبيعات للأصناف">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="move_type_filter"/>
                    </group>
                    <group>
                        <field name="partner_id"/>
                        <field name="salesperson_id"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print_report" type="object"
                            string="طباعة PDF" class="btn-primary"/>
                    <button string="إلغاء" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sale_report_wizard" model="ir.actions.act_window">
        <field name="name">تقرير مبيعات للأصناف</field>
        <field name="res_model">sale.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_sale_report_wizard_root"
              name="تقرير مبيعات الأصناف"
              parent="account.menu_finance_reports"
              action="action_sale_report_wizard"
              sequence="50"/>

</odoo>
