<odoo>
    <data>
        <!--Loan Postpone Tree-->
        <record id="tree_hr_postpone_loan_view" model="ir.ui.view">
            <field name="name">hr.loan.postpone.tree</field>
            <field name="model">hr.loan.postpone</field>
            <field name="arch" type="xml">
                <list string="Loan Postpones">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="employee_id"/>
                    <field name="loan_id"/>
                    <field name="amount"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!--Loan Postpones Form-->
        <record id="hr_postpone_loan_form_view" model="ir.ui.view">
            <field name="name">hr.loan.postpone.form</field>
            <field name="model">hr.loan.postpone</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_submit" type="object" string="Submit" class="oe_highlight"
                                invisible="state != 'draft'" />
                        <button name="action_cancel" type="object" string="Cancel"  invisible="state not in ('draft', 'submit')"/>
                        <button name="action_set_to_draft" type="object" string="Set To Draft" invisible="state != 'cancel'" />
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" class="oe_inline" readonly="1"/>
                            </h1>
                        </div>
                        <group colspan="4" col="4">
                            <field name="employee_id" required="1" options="{'no_create_edit': True}"
                                readonly="state != 'draft'"/>  
                                <field name="loan_id" required="1" options="{'no_create_edit': True}"
                                readonly="state != 'draft'"/>
                            <field name="amount" readonly="1"/>
                            <field name="date" readonly="1"/>
                            <field name="company_id" readonly="1"/>
    
                        </group>
                      
                        <notebook>
                            <page string="Installments">
                                <field name="loan_line_ids" required="1" readonly="state != 'draft'">
                                    <list editable="bottom">
                                        <!--field name="payment_date" readonly="1"/-->
                                        <field name="paid_date" string="Postpone Date"/>
                                        <field name="paid_amount" string="Postpone Amount" readonly="1"/>
                                        <button name="postpone_month" type="object" string="Postpone" invisible="1"/>
                                        <!--                                        <field name="paid"/>-->
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Action : HR Loan Postpone-->
        <record id="action_hr_loan_postpone" model="ir.actions.act_window">
            <field name="name">Loan postpone</field>
            <field name="res_model">hr.loan.postpone</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem name="Loans Postpones"
                  parent="menu_hr_loans"
                  id="menu_hr_loan_postpone"
                  action="action_hr_loan_postpone"
                  groups="hr.group_hr_manager,hr_custom.group_hr_general_manager"/>
    </data>
</odoo>