<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_product_pricing" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.product.pricing</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='product_setting_container']" position="inside">
                <setting help="Select currency for converted foreign cost.">
                    <field name="foreign_cost_currency_id"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
