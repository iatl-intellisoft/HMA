<template id="page_contact" name="HMA Contact">
  <t t-call="hma_website.hma_website_layout">
    <t t-set="additional_title" t-value="'إتش أم أيه | تواصل معنا'"/>
      <section class="page-hero">
        <div class="hero-pattern"/>
        <div class="hma-container hero-inner">
          <div class="hero-breadcrumb">
            <a href="/" data-ar="الرئيسية" data-en="Home">الرئيسية</a>
            <i class="fa fa-angle-left"/>
            <span data-ar="تواصل معنا" data-en="Contact Us">تواصل معنا</span>
          </div>
          <div class="hero-eyebrow"><i class="fa fa-envelope"/> <span data-ar="تواصل معنا" data-en="Contact Us">تواصل معنا</span></div>
          <h1><span data-ar="نحن " data-en="We're ">نحن </span><span class="accent" data-ar="هنا لخدمتك" data-en="Here to Help">هنا لخدمتك</span></h1>
          <p class="hero-desc" data-ar="تواصل معنا عبر أي قناة تفضلها — واتساب، هاتف، أو نموذج الاستفسار." data-en="Reach us through any channel you prefer — WhatsApp, phone, or the enquiry form.">تواصل معنا عبر أي قناة تفضلها — واتساب، هاتف، أو نموذج الاستفسار.</p>
        </div>
      </section>

      <section class="hma-section">
        <div class="hma-container">
          <div class="hma-grid-2">
            <!-- Contact Form -->
            <div class="fade-in">
              <div class="eyebrow-label"><i class="fa fa-paper-plane"/> <span data-ar="نموذج الاستفسار" data-en="Enquiry Form">نموذج الاستفسار</span></div>
              <h2 class="section-h mt-8" style="margin-bottom:28px;"><span data-ar="أرسل " data-en="Send Us ">أرسل </span><span class="red" data-ar="رسالتك" data-en="a Message">رسالتك</span></h2>

              <!-- Success banner -->
              <t t-if="success">
                <div class="alert-success">
                  <i class="fa fa-check-circle"/>
                  <div>
                    <strong data-ar="تم الإرسال بنجاح!" data-en="Sent Successfully!">تم الإرسال بنجاح!</strong><br/>
                    <span data-ar="شكراً لتواصلك معنا. سنرد عليك في أقرب وقت ممكن." data-en="Thank you for contacting us. We will reply as soon as possible.">شكراً لتواصلك معنا. سنرد عليك في أقرب وقت ممكن.</span>
                  </div>
                </div>
              </t>

              <!-- Validation error banner -->
              <t t-if="error">
                <div style="background:#FEF2F2;border:1.5px solid #FCA5A5;border-radius:var(--r-sm);padding:14px 18px;display:flex;align-items:flex-start;gap:10px;color:#991B1B;font-size:14px;font-weight:600;margin-bottom:20px;">
                  <i class="fa fa-exclamation-circle" style="font-size:18px;margin-top:1px;flex-shrink:0;color:#DC2626;"/>
                  <span t-esc="error"/>
                </div>
              </t>

              <!-- Contact form — CSRF token injected by Odoo website framework -->
              <t t-if="not success">
                <form action="/contact/submit" method="post" class="hma-form">
                  <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                  <div class="form-row">
                    <div class="form-group">
                      <label data-ar="الاسم الكامل *" data-en="Full Name *">الاسم الكامل *</label>
                      <input type="text" name="name" required="required"
                             maxlength="500"
                             data-ph-ar="أدخل اسمك الكامل" data-ph-en="Enter your full name"
                             placeholder="أدخل اسمك الكامل"
                             t-att-value="form_values and form_values.get('name', '') or ''"/>
                    </div>
                    <div class="form-group">
                      <label data-ar="رقم الهاتف" data-en="Phone Number">رقم الهاتف</label>
                      <input type="tel" name="phone"
                             maxlength="30"
                             data-ph-ar="09XXXXXXXX" data-ph-en="09XXXXXXXX"
                             placeholder="09XXXXXXXX"
                             t-att-value="form_values and form_values.get('phone', '') or ''"/>
                    </div>
                  </div>

                  <div class="form-group">
                    <label data-ar="البريد الإلكتروني" data-en="Email Address">البريد الإلكتروني</label>
                    <input type="email" name="email"
                           maxlength="254"
                           data-ph-ar="example@email.com" data-ph-en="example@email.com"
                           placeholder="example@email.com"
                           t-att-value="form_values and form_values.get('email', '') or ''"/>
                  </div>

                  <div class="form-group">
                    <label data-ar="موضوع الرسالة" data-en="Subject">موضوع الرسالة</label>
                    <input type="text" name="subject"
                           maxlength="500"
                           data-ph-ar="استفسار عن منتج / طلب جملة / ..." data-ph-en="Product enquiry / Wholesale order / ..."
                           placeholder="استفسار عن منتج / طلب جملة / ..."
                           t-att-value="form_values and form_values.get('subject', '') or ''"/>
                  </div>

                  <div class="form-group">
                    <label data-ar="رسالتك" data-en="Your Message">رسالتك</label>
                    <textarea name="message" rows="5" maxlength="2000"
                              data-ph-ar="اكتب رسالتك هنا..." data-ph-en="Write your message here..."
                              placeholder="اكتب رسالتك هنا...">
                      <t t-esc="form_values and form_values.get('message', '') or ''"/>
                    </textarea>
                  </div>

                  <button type="submit" class="btn-primary" style="width:100%;justify-content:center;padding:15px;">
                    <i class="fa fa-paper-plane"/> <span data-ar="إرسال الرسالة" data-en="Send Message">إرسال الرسالة</span>
                  </button>
                </form>
              </t>
            </div>

            <!-- Direct contact options -->
            <div class="fade-in fade-in-d2">
              <div class="eyebrow-label"><i class="fa fa-bolt"/> <span data-ar="تواصل سريع" data-en="Quick Contact">تواصل سريع</span></div>
              <h2 class="section-h mt-8" style="margin-bottom:28px;"><span data-ar="قنوات " data-en="Contact ">قنوات </span><span class="red" data-ar="التواصل" data-en="Channels">التواصل</span></h2>

              <!-- WhatsApp primary -->
              <a href="https://wa.me/249912390982" target="_blank"
                 style="display:flex;align-items:center;gap:16px;background:#25D366;color:#fff;padding:20px 24px;border-radius:var(--r);margin-bottom:14px;font-weight:800;font-size:16px;transition:all .25s;text-decoration:none;">
                <i class="fa fa-whatsapp" style="font-size:28px;"/>
                <div>
                  <div data-ar="تواصل عبر واتساب" data-en="Chat on WhatsApp">تواصل عبر واتساب</div>
                  <div style="font-size:12px;font-weight:400;opacity:.8;">0912 390 982</div>
                </div>
                <i class="fa fa-external-link" style="margin-right:auto;margin-left:0;opacity:.7;font-size:14px;"/>
              </a>

              <!-- Channel -->
              <a href="https://whatsapp.com/channel/0029Vb2RV5I4o7qV3Ev1L204" target="_blank"
                 style="display:flex;align-items:center;gap:16px;background:var(--dark);color:#fff;padding:20px 24px;border-radius:var(--r);margin-bottom:14px;font-weight:800;font-size:16px;transition:all .25s;text-decoration:none;">
                <i class="fa fa-whatsapp" style="font-size:28px;color:#25D366;"/>
                <div>
                  <div data-ar="قناة واتساب الرسمية" data-en="Official WhatsApp Channel">قناة واتساب الرسمية</div>
                  <div style="font-size:12px;font-weight:400;opacity:.5;" data-ar="اشترك لآخر العروض" data-en="Subscribe for latest offers">اشترك لآخر العروض</div>
                </div>
              </a>

              <!-- Hotline -->
              <a href="tel:6775"
                 style="display:flex;align-items:center;gap:16px;background:var(--brand);color:#fff;padding:20px 24px;border-radius:var(--r);margin-bottom:14px;font-weight:800;font-size:16px;transition:all .25s;text-decoration:none;">
                <i class="fa fa-phone-square" style="font-size:28px;"/>
                <div>
                  <div data-ar="الخط الساخن" data-en="Hotline">الخط الساخن</div>
