<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_bank_balance_report_wizard_form" model="ir.ui.view">
        <field name="name">bank.balance.report.wizard.form</field>
        <field name="model">bank.balance.report.wizard</field>
        <field name="arch" type="xml">
            <form string="تقرير أرصدة البنوك">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="journal_ids" widget="many2many_tags"
                               placeholder="كل حسابات البنوك (اتركه خاليًا)"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print_pdf" string="طباعة PDF"
                            type="object" class="btn-primary"/>
                    <button string="إلغاء" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bank_balance_report_wizard" model="ir.actions.act_window">
        <field name="name">تقرير أرصدة البنوك</field>
        <field name="res_model">bank.balance.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_bank_balance_report_wizard"
              name="تقرير أرصدة البنوك"
              parent="account.menu_finance_reports"
              action="action_bank_balance_report_wizard"
              sequence="55"/>

</odoo>
