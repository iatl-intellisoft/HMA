<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Payment Request Sequence-->
        <record id="custody_seq" model="ir.sequence">
            <field name="name">Payment Request</field>
            <field name="code">payment.request</field>
            <field name="padding">4</field>
            <field name="prefix">PR/%(range_year)s/</field>
            <field eval="False" name="company_id"/>
        </record>

         <!-- Payment Clearance Sequence -->
        <record id="clearance_seq" model="ir.sequence">
            <field name="name">Clearance Sequence</field>
            <field name="code">clearance.sequence</field>
            <field name="padding">4</field>
            <field name="prefix">PC/%(range_year)s/</field>
            <field eval="False" name="company_id"/>
        </record>

    </data>
</odoo>