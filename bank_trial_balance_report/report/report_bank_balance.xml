<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_bank_balance" model="ir.actions.report">
        <field name="name">تقرير أرصدة البنوك</field>
        <field name="model">bank.balance.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bank_trial_balance_report.report_bank_balance_template</field>
        <field name="report_file">bank_trial_balance_report.report_bank_balance_template</field>
        <field name="print_report_name">'تقرير أرصدة البنوك - %s' % (object.date_to)</field>
        <field name="binding_model_id" eval="False"/>
    </record>

    <template id="report_bank_balance_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page" style="direction: rtl; text-align: right;">
                    <h2 class="text-center">تقرير أرصدة البنوك</h2>
                    <p class="text-center">
                        عن الفترة من
                        <span t-esc="date_from" t-options="{'widget': 'date'}"/>
                        إلى
                        <span t-esc="date_to" t-options="{'widget': 'date'}"/>
                    </p>

                    <table class="table table-sm table-bordered" style="margin-top: 20px;">
                        <thead style="background-color: #f0f0f0;">
                            <tr>
                                <th>البنك</th>
                                <th>كود الحساب</th>
                                <th>اسم الحساب</th>
                                <th class="text-end">رصيد أول المدة</th>
                                <th class="text-end">مدين</th>
                                <th class="text-end">دائن</th>
                                <th class="text-end">رصيد آخر المدة</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="lines" t-as="line">
                                <td><span t-esc="line['journal_name']"/></td>
                                <td><span t-esc="line['account_code']"/></td>
                                <td><span t-esc="line['account_name']"/></td>
                                <td class="text-end">
                                    <span t-esc="'{:,.2f}'.format(line['initial_balance'])"/>
                                </td>
                                <td class="text-end">
                                    <span t-esc="'{:,.2f}'.format(line['debit'])"/>
                                </td>
                                <td class="text-end">
                                    <span t-esc="'{:,.2f}'.format(line['credit'])"/>
                                </td>
                                <td class="text-end">
                                    <span t-esc="'{:,.2f}'.format(line['ending_balance'])"/>
                                </td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr style="font-weight: bold; background-color: #f7f7f7;">
                                <td colspan="3">الإجمالي</td>
                                <td class="text-end">
                                    <span t-esc="'{:,.2f}'.format(total_initial)"/>
                                </td>
                                <td class="text-end">
                                    <span t-esc="'{:,.2f}'.format(total_debit)"/>
                                </td>
                                <td class="text-end">
                                    <span t-esc="'{:,.2f}'.format(total_credit)"/>
                                </td>
                                <td class="text-end">
                                    <span t-esc="'{:,.2f}'.format(total_ending)"/>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </t>
        </t>
    </template>

</odoo>
