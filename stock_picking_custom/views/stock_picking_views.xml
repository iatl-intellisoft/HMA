<odoo> 
    <record id="view_picking_form_inherit_vehicle" model="ir.ui.view">
        <field name="name">stock.picking.form.vehicle</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='location_id']" position="after">  
                <field name="delivery_amount"/>  
                <field name="delivered_cartons"/>    
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">  
                <field name="national_id"/>  
                <field name="vat_id"/>  
                <field name="phone"/> 
            </xpath>  
            <xpath expr="//field[@name='sale_payment_state']" position="after">  
                <field name="handling_price"/>  
                <field name="handling_amount"/>   
            </xpath> 

        </field>
    </record>

</odoo> 
