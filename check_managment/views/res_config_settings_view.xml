<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_account_custom_check_mangment" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.account.check.management</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="25"/>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
        <xpath expr="//app[@name='account']" position="inside">
            <block title="Check Follow up" name="check_follow_up_setting">
                <setting string="Check Settings" help="Configure your check follow-up settings here">
                    <div class="content-group">
                        <div class="row mt16">
                                <group col="2">
                                    <field name="account_receivable"/>
                                    <field name="account_payable"/>
                                    <field name="check_grace_period" style="width:30% !important;" string="check grace period day(s)" />
                                </group>
                            <!-- <label for="account_receivable"/>
                            <div class="o_setting_left_pane">
                                <field name="account_receivable"/>
                            </div>

                            <label for="account_payable"/>
                            <div class="o_setting_left_pane">
                                <field name="account_payable"/>
                            </div>
                            
                            <label for="check_grace_period"/>
                            <field name="check_grace_period" /> -->

                        </div>
                        <h2>Users To Be Notice When Create Cheque</h2>
                        <div class="row mt16 o_settings_container">
                            <label for="users_ids"/>
                            <div class="o_setting_left_pane">
                                <field name="users_ids" widget="many2many_tags"/>
                            </div>
                        </div>
                        <h2>Field to Create followup check entry in post</h2>
                        <div class="row mt16 o_settings_container">
                            <label for="post_entry"/>
                            <div class="o_setting_left_pane">
                                <field name="post_entry"/>
                            </div>
                        </div>
                    </div>
                </setting>
            </block>
        </xpath>
            
           
        </field>
    </record>

    <!-- <record id="action_check_managment_config" model="ir.actions.act_window">
        <field name="name">Settings</field>
        
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
    </record> -->


</odoo>
