<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Report action: appears as the PDF generated by the "Print" button -->
    <record id="action_report_sale_details" model="ir.actions.report">
        <field name="name">Sales Details</field>
        <field name="model">sale.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sale_report_wizard.report_sale_details_document</field>
        <field name="report_file">sale_report_wizard.report_sale_details_document</field>
        <field name="print_report_name">'Sales Details - %s' % (object.date_from or '')</field>
        <field name="binding_model_id" ref="model_sale_report_wizard"/>
        <field name="binding_type">report</field>
    </record>

    <!-- QWeb template -->
    <template id="report_sale_details_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Sales Details Report</h2>
                        <p>
                            <span t-if="o.date_from">From: <span t-esc="o.date_from"/></span>
                            <span t-if="o.date_to"> To: <span t-esc="o.date_to"/></span>
                        </p>

                        <table class="table table-sm o_main_table" style="font-size: 11px;">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>SO Ref</th>
                                    <th>Customer</th>
                                    <th>Salesperson</th>
                                    <th class="text-end">Invoice Total</th>
                                    <th class="text-end">Discount</th>
                                    <th class="text-end">Refund</th>
                                    <th class="text-end">Net Total</th>
                                    <th class="text-end">Paid</th>
                                    <th class="text-end">Net</th>
                                    <th>Bank Ref</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="lines" t-value="o.env['sale.report.line'].search([('wizard_id', '=', o.id)])"/>
                                <tr t-foreach="lines" t-as="line">
                                    <td><span t-esc="line.invoice_date"/></td>
                                    <td><span t-esc="line.sale_order_ref"/></td>
                                    <td><span t-esc="line.partner_id.name"/></td>
                                    <td><span t-esc="line.salesperson_id.name"/></td>
                                    <td class="text-end">
                                        <span t-esc="line.invoice_total" t-options="{'widget': 'monetary', 'display_currency': line.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="line.total_discount" t-options="{'widget': 'monetary', 'display_currency': line.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="line.refund_total" t-options="{'widget': 'monetary', 'display_currency': line.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="line.net_total" t-options="{'widget': 'monetary', 'display_currency': line.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="line.paid" t-options="{'widget': 'monetary', 'display_currency': line.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="line.net" t-options="{'widget': 'monetary', 'display_currency': line.currency_id}"/>
                                    </td>
                                    <td><span t-esc="line.bank_reference"/></td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="4"><strong>Total</strong></td>
                                    <td class="text-end"><strong t-esc="sum(lines.mapped('invoice_total'))" t-options="{'widget': 'float', 'precision': 2}"/></td>
                                    <td class="text-end"><strong t-esc="sum(lines.mapped('total_discount'))" t-options="{'widget': 'float', 'precision': 2}"/></td>
                                    <td class="text-end"><strong t-esc="sum(lines.mapped('refund_total'))" t-options="{'widget': 'float', 'precision': 2}"/></td>
                                    <td class="text-end"><strong t-esc="sum(lines.mapped('net_total'))" t-options="{'widget': 'float', 'precision': 2}"/></td>
                                    <td class="text-end"><strong t-esc="sum(lines.mapped('paid'))" t-options="{'widget': 'float', 'precision': 2}"/></td>
                                    <td class="text-end"><strong t-esc="sum(lines.mapped('net'))" t-options="{'widget': 'float', 'precision': 2}"/></td>
                                    <td/>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
