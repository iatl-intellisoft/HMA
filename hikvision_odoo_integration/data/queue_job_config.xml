<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hikvision_attendance_job_function" model="queue.job.function">
        <field name="model_id" ref="model_hikvision_device"/>
        <field name="method">job_download_attendance</field>
        <field name="channel_id" ref="queue_job.channel_root"/>
        <field name="retry_pattern" eval="{1: 60, 2: 180, 3: 300, 5: 600}"/>
    </record>
    <record id="hikvision_all_attendance_job_function" model="queue.job.function">
        <field name="model_id" ref="model_hikvision_device"/>
        <field name="method">job_download_all_attendance</field>
        <field name="channel_id" ref="queue_job.channel_root"/>
        <field name="retry_pattern" eval="{1: 60, 2: 180, 3: 300, 5: 600}"/>
    </record>
</odoo>