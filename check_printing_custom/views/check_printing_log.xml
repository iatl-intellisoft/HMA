<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <record id="check_printing_log_form" model="ir.ui.view">
            <field name="name">check.printing.log.form</field>
            <field name="model">check.printing.log</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="payment_id"/>
                            <field name="check_no"/>
                            <field name="reason_id"/>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>


        <record id="check_printing_log_tree" model="ir.ui.view">
            <field name="name">check printing log tree</field>
            <field name="model">check.printing.log</field>
            <field name="arch" type="xml">
                <list>
                    <field name="payment_id"/>
                    <field name="check_no"/>
                    <field name="reason_id"/>
                </list>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_check_printing_log">
            <field name="name">Check Printing Log</field>
            <field name="res_model">check.printing.log</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="check_printing_log_tree"/>
        </record>

        <menuitem action="action_check_printing_log" id="check_printing_log" parent="account.account_account_menu"/>


        <record id="act_payment_2_check_log" model="ir.actions.act_window">
            <field name="name">Check Log</field>
            <field name="res_model">check.printing.log</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('payment_id','=',active_id)]</field>
            <field name="view_id" ref="check_printing_custom.check_printing_log_tree"/>

        </record>


        <record id="payment_form_inherit" model="ir.ui.view">
            <field name="name">account.payment.form</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <field name="log_number" invisible="1"/>
                    <button name="%(check_printing_custom.act_payment_2_check_log)d"
                            invisible="state not in ['sent','posted'] or log_number == 0"
                            string="Check Printing Logs" type="action" class="oe_stat_button"
                            icon="fa-pencil-square-o"/>
                </xpath>

                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="beneficiary"
                           invisible="payment_method_code != 'check_printing'"
                           readonly="state in ('sent','reconciled','cancelled')"/>
                </xpath>


            </field>
        </record>
    </data>
</odoo>
