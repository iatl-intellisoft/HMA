<odoo>
<data>
<record id="view_employee_monthly_report_pivot" model="ir.ui.view">
        <field name="name">hr.employee.pivot</field>
        <field name="model">hr.contract</field>
        <field name="arch" type="xml">
            <pivot>
            <field name="employee_id" type="row"/>
            <field name="age" type="measure" />
            <field name="service_years" type="measure"/>
            </pivot>
        </field>
</record>



 <record id="employee_month_report_view_search" model="ir.ui.view">
            <field name="name">employee.month.report.search</field>
            <field name="model">hr.contract</field>
            <field name="arch" type="xml">
                <search string="Search Contract">
                    <field name="name" string="Contracts"/>
                    <field name="service_years"/>
                     <filter string=" Contracts in offer and open state" name="employee_working" domain="[('state','in',['offer','open'])]"/>
                    <filter string="Employee Leaved" name="employee_leaved" domain="[('service_years','&lt;=',0.25),('state','not in',['offer','open'])]"/>


                
                    </search>
            </field>
        </record>




<record id="action_employee_monthly_report" model="ir.actions.act_window">
            <field name="name">Monthly Report</field>
            <field name="res_model">hr.contract</field>
            <!-- <field name="view_type">form</field> -->
            <field name="view_mode">pivot</field>
            <field name='context'>{'search_default_employee_working': 1}</field>
            <field name="view_id" ref="view_employee_monthly_report_pivot"/>
            <field name="search_view_id" ref="employee_month_report_view_search"/>

</record>


 <menuitem id="menu_employee_monthly_report_id" name="Employee Monthly report"  action="action_employee_monthly_report" parent="hr.hr_menu_hr_reports" sequence="3"/>





</data>
</odoo>