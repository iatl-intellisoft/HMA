<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_sale_payment_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.internal_layout">
                    <div class="page" style="direction: rtl; text-align: right;">
                        <h2>تقرير المبيعات - السداد بالتفصيل</h2>
                        <p>
                            الفترة من <span t-esc="doc.date_from"/> إلى <span t-esc="doc.date_to"/>
                        </p>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>تاريخ الدفعة</th>
                                    <th>رقم الدفعة</th>
                                    <th>رقم أمر البيع</th>
                                    <th>العميل</th>
                                    <th>طريقة السداد</th>
                                    <th>رقم العملية البنكية</th>
                                    <th>قيمة السداد</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.line_ids" t-as="line">
                                    <td><span t-esc="line.payment_date"/></td>
                                    <td><span t-esc="line.payment_name"/></td>
                                    <td><span t-esc="line.sale_order_name"/></td>
                                    <td><span t-esc="line.partner_id.name"/></td>
                                    <td><span t-esc="line.payment_method_label"/></td>
                                    <td><span t-esc="line.bankak_transaction_number"/></td>
                                    <td><span t-esc="line.amount"/></td> 
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="5" style="text-align:left;"><strong>الإجمالي</strong></td>
                                    <td><strong><span t-esc="sum(doc.line_ids.mapped('amount'))"/></strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
