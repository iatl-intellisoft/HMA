<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_delivery_control" model="ir.ui.view">
        <field name="name">sale.order.form.delivery.control</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
		         <field
                    name="payment_warning"
                    widget="html"
                    readonly="1"
                    invisible="payment_completed"/>
            </xpath>
        </field>
    </record>

<record id="view_order_list_inherit_delivery_control" model="ir.ui.view">
        <field name="name">sale.order.list.delivery.control</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">

                <field
   		 name="payment_status"
   		 widget="badge"
  	         decoration-primary="payment_status == 'approved'"
   		 decoration-warning="payment_status == 'waiting_payment'"
   		 decoration-success="payment_status == 'paid'"/>
            </xpath>
        </field>
    </record>
</odoo> 
