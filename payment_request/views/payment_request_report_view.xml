<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
<template id="clearnce_report_template">
    <t t-call="web.external_layout">
        <t t-foreach="docs" t-as="doc">
            <div class="page">

                <h2 style="text-align:center;">
                    Fuel Inventory (عهدة الوقود)
                </h2>

                <table class="table table-bordered" style="width:100%; direction:rtl;">
                    <thead>
                        <tr>
                            <th>التاريخ</th>
                            <th>رقم العهدة</th>
                            <th>اسم المستلم</th>
                            <th>المبلغ المسلم</th>
                            <th>المصروف</th>
                            <th>الرصيد</th>
                            <th>نوع الحركة</th>
                            <th>المرجع</th>
                            <th>البيان</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="custody_amount" t-value="0"/>
                        <t t-set="expenses_amount" t-value="0"/>

                        <t t-foreach="doc.get_report_data()" t-as="line">
                            <tr>
                                <td><t t-esc="line['date']"/></td>
                                <td><t t-esc="line['request']"/></td>
                                <td><t t-esc="line['employee']"/></td>
                                <td><t t-esc="line['in']"/></td>
                                <td><t t-esc="line['out']"/></td>
                                <td><t t-esc="line['balance']"/></td>
                                <td><t t-esc="line['type']"/></td>
                                <td><t t-esc="line['ref']"/></td>
                                <td><t t-esc="line['desc']"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>

            </div>
        </t>
    </t>
</template>
        <record id="action_report_payment_request" model="ir.actions.report">
            <field name="name">Payment Request</field>
            <field name="model">payment.request</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">payment_request.clearnce_report_template</field>
            <field name="binding_model_id" ref="payment_request.model_payment_request"/>
        </record>
    </data>
</odoo>