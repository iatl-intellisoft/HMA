<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_delivery_control" model="ir.ui.view">
        <field name="name">sale.order.form.delivery.control</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">

		<!-- <div class=" alert-warning mb-0 me-auto" role="alert" invisible="state != 'pending_payment'"> -->
		<div class=" alert-warning mb-0 me-auto" role="alert">
              
                    <button name="action_open_down_payment_wizard" type="object"
                            string="إنشاء فاتورة دفعة مقدمة" class="btn-primary mt-2"/>
                    <button name="action_check_payment_now" type="object"
                            string="تحقق من الدفع الآن" class="btn-secondary mt-2"/> 
                </div>
            </xpath>
        </field>
    </record>
</odoo>
