<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_view_hikvision_management" model="ir.actions.act_window">
        <field name="name">User Management</field>
        <field name="res_model">hikvision.management</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="hikvision_management_view_form" model="ir.ui.view">
        <field name="name">hikvision.management.view.form</field>
        <field name="model">hikvision.management</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="manage_users"/>
                        <field name="employee_id"/>
                        <field name="device_id"/>
                    </group>
                </group>
                <footer>
                    <button class="btn btn-primary" string="Confirm"
                            name="action_confirm_user_management" type="object"/>
                    <button class="btn btn-secondary" string="DISCARD" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>