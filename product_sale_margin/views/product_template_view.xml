<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Product Template Form View -->
    <record id="product_template_form_view_inherit_foreign_cost_margin" model="ir.ui.view">
        <field name="name">product.template.form.foreign.cost.margin</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='standard_price_uom']" position="after">
                <label for="margin_percent"/>
                <div>
                    <field name="margin_percent" class="oe_inline"/>
                    <span class="oe_inline"> % </span>
                </div>
            </xpath>
        </field>
    </record>
</odoo>