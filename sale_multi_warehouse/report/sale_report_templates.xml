<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="report_saleorder_document" inherit_id="sale.report_saleorder_document">
	<xpath expr="//th[@name='th_quantity']" position="before">
        <th name="th_warehouse" class="text-right">Warehouse</th>
	</xpath>
	<xpath expr="//td[@name='td_quantity']" position="before">
        <td name="td_warehouse" class="text-right">
        	<span t-field="line.warehouse_id.name"/>
        </td>
	</xpath>
</template>
</odoo>