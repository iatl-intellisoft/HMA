<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_payroll_account_custom_inherit" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.contract</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr_payroll.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='hr_payroll_accountant']" position="after">

                    <h2>Employees Consider Sign</h2>
                    <div class="row mt16 o_settings_container" name="contract_setting_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            
                            <div class="o_setting_right_pane">
                                <span class="fa fa-lg fa-building-o" title="Values set here are company-specific." aria-label="Values set here are company-specific." groups="base.group_multi_company" role="img"/>
                                <div class="text-muted">
                                 Employee Consider Sign
                                </div>
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label for="first_employee_id" class="col-lg-4 o_light_label"/>
                                        <field name="first_employee_id" required="1"/>
                                    </div>

                                    <div class="row mt16">
                                        <label for="second_employee_id" class="col-lg-4 o_light_label"/>
                                        <field name="second_employee_id" required="1"/>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
            </xpath>
        </field>
    </record>
</odoo>
