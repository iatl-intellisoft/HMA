<odoo>
    <record id="view_product_form_safety" model="ir.ui.view">
        <field name="name">product.template.form.safety</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
             <xpath expr="//field[@name='sale_ok']" position="before">                     
                <field name="is_safety_equipment" class='oe_title'/>
                <label for="is_safety_equipment"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Safety Equipment Details"  invisible="is_safety_equipment == False">
                    <group>                     
                        <field name="safety_state" />
                        <field name="safety_category"/>
                        <field name="extinguisher_type"/>
                        <field name="country_id"/>
                        <field name="life_span"/>
                        <field name="validity_date"/>
                        <field name="purchase_date"/>
                        <field name="last_inspection_date"/>
                    </group>
                    <group>
                        <field name="expiry_date" readonly="1"/>
                        <field name="remaining_days" readonly="1"/>
                    </group>
                </page>

            </xpath>

        </field>
    </record>

</odoo>