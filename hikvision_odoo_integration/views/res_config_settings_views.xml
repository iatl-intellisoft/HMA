<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="res_config_settings_view_form_hr_approval" model="ir.ui.view">
    <field name="name">res.config.settings.view.form.hr.approval</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="hr_attendance.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//block[@name='overtime_settings']" position="after">
        <block title="Hikvision" id="hikvision_setting_container" groups="hr.group_hr_manager,hr.group_hr_user,hr_attendance.group_hr_attendance_manager">
          <setting id="hr_attendance_approval"
                   string="HR Approval"
                   help="Enable HR approval for attendance that doesn't meet minimum working hours">
            <field name="enable_hr_approval"/>
          </setting>
           <setting id="minimum_working_hours"
                   string="Minimum Working Hours"
                   help="Minimum working hours required per day without requiring approval"
                   invisible="not enable_hr_approval">
            <field name="minimum_working_hours"/>
          </setting>
        </block>
      </xpath>
    </field>
  </record>
</odoo>