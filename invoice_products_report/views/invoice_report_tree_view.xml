<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_invoice_report_line_tree" model="ir.ui.view">
        <field name="name">invoice.report.line.tree</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <list string="تفاصيل الفواتير بالمنتجات"
                  default_group_by="product_id"
                  create="0" edit="0" delete="0" import="0">
                <field name="move_id" string="رقم الفاتورة"/>
                <field name="invoice_date" string="تاريخ الفاتورة"/>
                <field name="partner_id" string="العميل/المورد"/>
                <field name="product_id" string="المنتج"/>
                <field name="quantity" string="الكمية" sum="إجمالي الكمية"/>
                <field name="price_unit" string="سعر الوحدة"/>
                <field name="discount" string="الخصم %" optional="hide"/>
                <field name="price_subtotal" string="الإجمالي (بدون ضريبة)"
                       sum="إجمالي (بدون ضريبة)"/>
                <field name="price_total" string="الإجمالي (شامل الضريبة)"
                       sum="إجمالي (شامل الضريبة)"/>
                <field name="currency_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_invoice_report_search" model="ir.ui.view">
        <field name="name">invoice.report.line.search</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <search string="بحث في تقرير الفواتير">
                <field name="product_id"/>
                <field name="partner_id"/>
                <field name="move_id"/>
                <filter string="فواتير مبيعات"
                        name="sale_invoices"
                        domain="[('move_id.move_type','=','out_invoice')]"/>
                <filter string="فواتير مشتريات"
                        name="purchase_invoices"
                        domain="[('move_id.move_type','=','in_invoice')]"/>
                <group expand="0" string="تجميع حسب">
                    <filter string="المنتج" name="group_product"
                            context="{'group_by':'product_id'}"/>
                    <filter string="العميل/المورد" name="group_partner"
                            context="{'group_by':'partner_id'}"/>
                    <filter string="الفاتورة" name="group_invoice"
                            context="{'group_by':'move_id'}"/>
                    <filter string="شهر الفاتورة" name="group_month"
                            context="{'group_by':'invoice_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
