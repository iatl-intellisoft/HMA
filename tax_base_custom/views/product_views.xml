<odoo>
<record id="product_template_tax_base_view" model="ir.ui.view">
    <field name="name">product.template.tax.base</field>
    <field name="model">product.template</field>
    <field name="inherit_id" ref="product.product_template_only_form_view"/>
    <field name="arch" type="xml">

        <xpath expr="//field[@name='list_price']" position="after">
            <group>
                <field name="tax_base_amount"/>
            </group>
        </xpath>

    </field>
</record>
<record id="product_product_tax_base_view" model="ir.ui.view">
    <field name="name">product.product.tax.base</field>
    <field name="model">product.product</field>
    <field name="inherit_id" ref="product.product_normal_form_view"/>
    <field name="arch" type="xml">

        <xpath expr="//field[@name='lst_price']" position="after">
            <group>
                <field name="tax_base_amount"/>
            </group>
        </xpath>

    </field>
</record>
<record id="invoice_tax_base_view" model="ir.ui.view">
    <field name="name">account.move.tax.base</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">
 
        <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='price_unit']" position="after">
            <field name="tax_base_amount"/>
        </xpath>
 
        <xpath expr="//field[@name='invoice_line_ids']/form//field[@name='price_unit']" position="after">
            <field name="tax_base_amount"/>
        </xpath>

    </field>
</record>

</odoo>