<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="page_index" name="HMA Home">
  <t t-call="website.layout">
    <t t-set="additional_title" t-value="'إتش أم أيه | الرئيسية'"/>
    <t t-set="head">
      <style>
        .hero { background:var(--dark); min-height:88vh; display:flex; align-items:center; position:relative; overflow:hidden; padding:80px 0; }
        .hero::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse 55% 85% at 90% 45%,rgba(200,16,46,.2) 0%,transparent 65%),radial-gradient(ellipse 40% 60% at 10% 85%,rgba(200,16,46,.08) 0%,transparent 60%); }
        .hero-pattern { position:absolute; inset:0; background-image:linear-gradient(rgba(255,255,255,.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.02) 1px,transparent 1px); background-size:44px 44px; }
        .hero-inner { position:relative; z-index:2; display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center; }
        @media(max-width:900px){.hero-inner{grid-template-columns:1fr;}}
        .hero-tag { display:inline-flex; align-items:center; gap:8px; background:rgba(200,16,46,.15); border:1px solid rgba(200,16,46,.35); padding:6px 16px; border-radius:100px; font-size:12px; font-weight:700; color:var(--brand); margin-bottom:24px; }
        .hero-h1 { font-size:clamp(40px,5.5vw,68px); font-weight:900; color:#fff; line-height:1.05; margin-bottom:12px; }
        .hero-h1 .red { color:var(--brand); }
        .hero-slogan { font-size:17px; color:rgba(255,255,255,.5); font-style:italic; margin-bottom:28px; }
        .hero-p { font-size:16px; color:rgba(255,255,255,.58); line-height:1.85; max-width:500px; margin-bottom:36px; }
        .hero-ctas { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:48px; }
        .hero-stats { display:flex; border:1px solid rgba(255,255,255,.1); border-radius:var(--r); overflow:hidden; background:rgba(255,255,255,.03); flex-wrap:wrap; }
        .hs { padding:18px 28px; border-left:1px solid rgba(255,255,255,.1); text-align:center; }
        .hs:last-child { border-left:none; }
        .hs-n { font-size:28px; font-weight:900; color:var(--brand); line-height:1; }
        .hs-l { font-size:11px; color:rgba(255,255,255,.4); margin-top:5px; font-weight:600; }
        .hero-visual { display:flex; flex-direction:column; gap:16px; }
        .hv-card { background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); border-radius:var(--r); padding:20px 22px; display:flex; align-items:center; gap:16px; transition:all .3s; }
        .hv-card:hover { border-color:var(--brand); background:rgba(200,16,46,.12); }
        .hv-icon { width:48px; height:48px; border-radius:var(--r-sm); display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0; }
        .hv-icon.red { background:rgba(200,16,46,.25); color:var(--brand); }
        .hv-icon.gold { background:rgba(200,153,42,.2); color:var(--gold); }
        .hv-icon.white { background:rgba(255,255,255,.1); color:rgba(255,255,255,.7); }
        .hv-info h4 { font-size:15px; font-weight:800; color:#fff; }
        .hv-info p { font-size:12px; color:rgba(255,255,255,.45); margin-top:2px; }
        /* Featured products */
        .feat-products-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:24px; }
        @media(max-width:1100px){.feat-products-grid{grid-template-columns:repeat(2,1fr);}}
        @media(max-width:700px){.feat-products-grid{grid-template-columns:1fr;}}
        /* Trust cards */
        .trust-cards { display:grid; grid-template-columns:repeat(4,1fr); gap:24px; margin-top:48px; }
        @media(max-width:1100px){.trust-cards{grid-template-columns:repeat(2,1fr);}}
        @media(max-width:600px){.trust-cards{grid-template-columns:1fr;}}
        .trust-card { background:var(--surface); border:1.5px solid var(--border); border-radius:var(--r); padding:28px; text-align:center; transition:all .3s; }
        .trust-card:hover { border-color:var(--brand); transform:translateY(-4px); box-shadow:var(--sh); }
        .tc-icon { width:52px; height:52px; border-radius:var(--r-sm); display:flex; align-items:center; justify-content:center; font-size:20px; margin:0 auto 16px; }
        .tc-icon.red { background:var(--brand-light); color:var(--brand); }
        .tc-icon.gold { background:var(--gold-light); color:var(--gold); }
        .tc-icon.green { background:#D1FAE5; color:#059669; }
        .tc-icon.blue { background:#DBEAFE; color:#2563EB; }
        .trust-card h3 { font-size:16px; font-weight:800; color:var(--ink); margin-bottom:8px; }
        .trust-card p { font-size:13px; color:var(--ink-mid); line-height:1.7; }
        /* Sectors */
        .sectors-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:28px; margin-top:40px; }
        @media(max-width:900px){.sectors-grid{grid-template-columns:1fr;}}
        .sector-card { background:var(--dark); border:1px solid rgba(255,255,255,.08); border-radius:var(--r); padding:32px; position:relative; overflow:hidden; transition:all .3s; }
        .sector-card:hover { border-color:var(--brand); box-shadow:var(--sh-br); }
        .sc-num { font-size:64px; font-weight:900; color:rgba(255,255,255,.04); position:absolute; top:16px; left:20px; line-height:1; font-style:italic; }
        .sc-icon { width:52px; height:52px; border-radius:var(--r-sm); display:flex; align-items:center; justify-content:center; font-size:22px; margin-bottom:20px; }
        .sc-icon.active { background:rgba(200,16,46,.2); color:var(--brand); }
        .sc-icon.prep { background:rgba(200,153,42,.15); color:var(--gold); }
        .sc-icon.future { background:rgba(255,255,255,.08); color:rgba(255,255,255,.5); }
        .sc-title { font-size:18px; font-weight:800; color:#fff; margin-bottom:10px; }
        .sc-desc { font-size:13px; color:rgba(255,255,255,.45); line-height:1.7; margin-bottom:16px; }
        .sc-status { display:inline-flex; align-items:center; gap:6px; padding:5px 14px; border-radius:100px; font-size:12px; font-weight:700; }
        .sc-status.active { background:rgba(200,16,46,.15); color:var(--brand); border:1px solid rgba(200,16,46,.3); }
        .sc-status.prep { background:rgba(200,153,42,.1); color:var(--gold); border:1px solid rgba(200,153,42,.3); }
        .sc-status.future { background:rgba(255,255,255,.06); color:rgba(255,255,255,.4); border:1px solid rgba(255,255,255,.1); }
        /* Chinbull highlight */
        .chin-highlight { background:var(--dark); padding:80px 0; }
        .chin-hi-inner { display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center; }
        @media(max-width:900px){.chin-hi-inner{grid-template-columns:1fr;}}
        .chin-hi-title { font-size:clamp(32px,4vw,52px); font-weight:900; color:#fff; line-height:1.1; margin-bottom:20px; }
        .chin-hi-title .red { color:var(--brand); }
        .chin-hi-desc { font-size:15px; color:rgba(255,255,255,.55); line-height:1.85; margin-bottom:28px; }
        .chin-hi-ctas { display:flex; gap:12px; flex-wrap:wrap; margin-top:32px; }
        .chin-hi-card { background:rgba(200,153,42,.06); border:1px solid rgba(200,153,42,.2); border-radius:var(--r-lg); padding:36px; }
        .chin-hi-logo { font-size:40px; font-weight:900; color:var(--gold); letter-spacing:-1px; margin-bottom:12px; text-align:center; }
        .chin-hi-card h3 { font-size:22px; font-weight:800; color:#fff; margin-bottom:12px; text-align:center; }
        .chin-hi-card p { font-size:14px; color:rgba(255,255,255,.5); text-align:center; margin-bottom:24px; }
        .chin-hi-features { display:flex; flex-direction:column; gap:10px; margin-bottom:28px; }
        .chin-hi-feat { display:flex; align-items:center; gap:10px; font-size:14px; font-weight:600; color:rgba(255,255,255,.65); }
        .chin-hi-feat i { color:var(--gold); font-size:12px; }
      </style>
    </t>

    <div class="hma-website">
