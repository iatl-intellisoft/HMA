<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="hikvision_logs_view_tree" model="ir.ui.view">
        <field name="name">hikvision.logs.view.tree</field>
        <field name="model">hikvision.logs</field>
        <field name="arch" type="xml">
            <list string="Attendance" create="false" >
                <field name="employee_id"/>
                <field name="date"/>
                <field name="punch_type"/>
                <field name="attendance_type"/>
                <field name="punching_time"/>
            </list>
        </field>
    </record>
    <record id="hikvision_odoo_integration.hikvision_logs_action" model="ir.actions.act_window">
        <field name="name">Hikvision Logs</field>
        <field name="res_model">hikvision.logs</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>