<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="hikvision_device_view_form" model="ir.ui.view">
        <field name="name">hikvision.device.view.form</field>
        <field name="model">hikvision.device</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="test_connection"
                            string="Test Connection"
                            type="object" class="oe_highlight"
                    />
                    <button name="fetch_and_create_attendance"
                            string="Download Todays Attendance"
                            type="object" class="oe_highlight"
                    />
                    <button name="download_all_attendance"
                            string="Download All Attendance"
                            type="object" class="oe_highlight"
                    />
                    <button name="fetch_employees"
                            string="Fetch Employees"
                            type="object" class="oe_highlight"
                    />
                    <button name="fetch_logs"
                            string="Fetch Logs"
                            type="object" class="oe_highlight"
                    />
                    <button name="set_time"
                            string="Set Time"
                            type="object" class="oe_highlight"
                    />
                    <button name="%(hikvision_odoo_integration.action_view_hikvision_management)d"
                            string="User Management"
                            type="action" class="oe_highlight"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="ip_address"/>
                        <field name="username"/>
                        <field name="password"/>
                        <field name="image" widget="image" invisible="1"/>
                    </group>
                    <notebook>
                        <page string="Device Information">
                            <group>
                                <field name="device_name"/>
                                <field name="device_id"/>
                                <field name="device_model"/>
                                <field name="device_serial_no"/>
                                <field name="device_mac_address"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <!--    Defined all menus here -->
    <record id="hikvision_device_details_action" model="ir.actions.act_window">
        <field name="name">Hikvision Device</field>
        <field name="res_model">hikvision.device</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="hikvision_menu"
              name="Hikvision Device"
              parent="hr_attendance.menu_hr_attendance_root"
              sequence="21"/>
    <menuitem id="hikvision_sub_menu"
              action="hikvision_device_details_action"
              parent="hikvision_menu"
              sequence="21"/>
    <menuitem id="hikvision_logs_sub_menu"
              action="hikvision_logs_action"
              parent="hikvision_menu"
              sequence="21"/>
    <menuitem id="attendance_approval_menu"
              name="Attendance Approval"
              action="action_attendance_approval"
              parent="hikvision_menu"
              sequence="21"
              groups="hikvision_odoo_integration.group_attendance_approval_menu"/>
</odoo>