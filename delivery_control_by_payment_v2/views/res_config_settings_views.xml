<?xml version="1.0" encoding="utf-8"?>
<odoo> 
    <record id="res_config_settings_view_form_inherit_sale_approval" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.sale.management</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='sale_management']" position="inside">
                <block title="اعتماد المبيعات">
                    <setting id="sale_approval_setting"
                             string="اعتماد أوامر البيع للعملاء المعتمدين"
                             help="حدد الموظف المسؤول عن اعتماد أوامر البيع الخاصة بالعملاء 'المعتمدين' قبل إنشاء أمر التوصيل لهم">
                        <field name="sale_approval_user_id"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
