<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_invoice_report_wizard_form" model="ir.ui.view">
        <field name="name">invoice.report.wizard.form</field>
        <field name="model">invoice.report.wizard</field>
        <field name="arch" type="xml">
            <form string="تقرير الفواتير بالمنتجات">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="move_type"/>
                    </group>
                    <group>
                        <field name="only_posted"/>
                        <field name="partner_id"/>
                        <field name="product_id"/>
                    </group>
                </group>
                <footer>
                    <button name="action_view_report"
                            string="عرض التقرير"
                            type="object"
                            class="btn-primary"/> 
                    
                    <button name="action_print_pdf"
                            string="طباعة التقرير"
                            type="object"
                            class="btn-primary"/> 
                    
                    <button string="إلغاء" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_invoice_report_wizard" model="ir.actions.act_window">
        <field name="name">تقرير الفواتير بالمنتجات</field>
        <field name="res_model">invoice.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
