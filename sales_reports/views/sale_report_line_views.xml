<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List (tree) view ─────────────────────────────────────────────────── -->
    <record id="sale_report_line_view_list" model="ir.ui.view">
        <field name="name">sale.report.line.list</field>
        <field name="model">sale.report.line</field>
        <field name="arch" type="xml">
            <!-- decoration-warning highlights the ENTIRE ROW yellow when net > 0 -->
            <list string="Sales Details"
                  create="0"
                  edit="0"
                  delete="0"
                  export_xlsx="1"
                  decoration-warning="net &gt; 0">

                <!-- Hidden: used by Monetary widget for formatting only -->
                <field name="currency_id" column_invisible="1"/>

                <field name="sale_order_ref"  string="Sale Order Ref"/>
                <field name="invoice_date"    string="Invoice Date"/>
                <field name="salesperson_id"  string="Salesperson"/>
                <field name="partner_id"      string="Customer"/>

                <field name="total_discount"
                       string="Total Discount"
                       sum="Total Discount"
                       optional="show"/>

                <field name="invoice_total"
                       string="Invoice Total"
                       sum="Invoice Total"/>

                <field name="refund_total"
                       string="Refunds Total"
                       sum="Refunds Total"/>

                <field name="net_total"
                       string="Net Total"
                       sum="Net Total"/>

                <field name="paid"
                       string="Paid"
                       sum="Paid"/>

                <field name="net"
                       string="Net"
                       sum="Net"/>
                
                <field name="bank_reference" 
                    string="Bank Ref"/>

            </list>
        </field>
    </record>

    <!-- ── Search view ──────────────────────────────────────────────────────── -->
    <record id="sale_report_line_view_search" model="ir.ui.view">
        <field name="name">sale.report.line.search</field>
        <field name="model">sale.report.line</field>
        <field name="arch" type="xml">
            <search string="Sales Details">
                <field name="sale_order_ref" string="Sale Order"/>
                <field name="partner_id"     string="Customer"/>
                <field name="salesperson_id" string="Salesperson"/>
                <separator/>
                <filter name="filter_unpaid"
                        string="Unpaid"
                        domain="[('net', '&gt;', 0)]"/>
                <filter name="filter_paid"
                        string="Fully Paid"
                        domain="[('net', '=', 0)]"/>
                <filter name="filter_has_refund"
                        string="Has Refunds"
                        domain="[('refund_total', '&gt;', 0)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_salesperson"
                            string="Salesperson"
                            context="{'group_by': 'salesperson_id'}"/>
                    <filter name="group_customer"
                            string="Customer"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_date"
                            string="Invoice Date"
                            context="{'group_by': 'invoice_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Stand-alone action (used by the wizard's return value) ───────────── -->
    <record id="action_sale_report_line" model="ir.actions.act_window">
        <field name="name">Sales Details</field>
        <field name="res_model">sale.report.line</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
