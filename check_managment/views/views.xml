<odoo>
    <data>
        <record model="ir.ui.view" id="followup_pivot_view">
            <field name="name">followup pivot view</field>
            <field name="model">account.checks.followup</field>
            <field name="arch" type="xml">
                <pivot>
                    <field name='state' type='row'/>
                    <field name='beneficiary' type='row'/>
                    <field name='amount' type='measure'/>
                </pivot>
            </field>
        </record>

        <record model="ir.ui.view" id="view_account_journal_form_inherit">
            <field name="name">view.account.journal.form.inherit</field>
            <field name="model">account.journal</field>
            <field name="inherit_id" ref="account.view_account_journal_form"/>
            <field name="arch" type="xml">

                <xpath expr="//page[@name='bank_account']/group" position="after">
                    <group col='4'>

                        <field name='check_undercollection_account_id'
                            required="type == 'bank'"
                            invisible="type != 'bank'"/>
                        <field name='check_outstanding_account_id'
                            required="type == 'bank'"
                            invisible="type != 'bank'"/>
                        <field name='returned_check_debit_account_id'
                            required="type == 'bank'"
                            invisible="type != 'bank'"/>
                        <field name='returned_check_credit_account_id'
                            required="type == 'bank'"
                            invisible="type != 'bank'"/>

                    </group>

                </xpath>
            </field>
        </record>

        <record model="ir.ui.view" id="view_account_payment_form_inherit">
            <field name="name">account.view.account.payment.form.inherit</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='memo']" position="after">

                    <field widget="radio" name='check_type'
                            required="payment_method_code == 'check_printing'"
                            invisible="payment_method_code != 'check_printing'"/>
                    <field name="date_due"
                            required="check_type == 'indirect'"
                            invisible="check_type != 'indirect'"/>
                </xpath>
            </field>
        </record>


        <record id="view_tree_account_checks_followup" model="ir.ui.view">
            <field name="name">view.tree.account.checks.followup</field>
            <field name="model">account.checks.followup</field>
            <field name="arch" type="xml">
                <list create='0'>
                    <field name="payment_id"/>
                    <field name="partner_id"/>
                    <field name="journal_id"/>
                    <field name="amount"/>
                    <field name='check_no'/>
                    <field name='state'/>
                </list>
            </field>
        </record>

        <record id="action_move_line_form" model="ir.actions.act_window">
            <field name="name">Journal Entry</field>
            <field name="res_model">account.move</field>
            <!-- <field name="view_type">form</field> -->
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_check_followup_id': active_id}</field>
            <field name="domain">[('check_followup_id','=',active_id)]</field>
        </record>

        <record id="view_form_account_checks_followup" model="ir.ui.view">
            <field name="name">view.form.account.checks.followup</field>
            <field name="model">account.checks.followup</field>
            <field name="arch" type="xml">
                <form create='0'>
                    <header>
                        <button class="oe_highlight" name='withdrawn' string='Withdrawn' type='object'
                                invisible="state not in ('outstanding', 'collection')"/>
                        <button class="oe_highlight" name='withdrawn_close' string='Withdrawn &amp; Close' type='object'
                                invisible="state not in ('outstanding', 'collection')"/>
                        <button name='close' string='Close' type='object' 
                                invisible="state not in ('paid', 'deposited')" class="oe_highlight"/>
                        <button name='returned' string='Return' type='object' 
                                invisible="state not in ('paid', 'deposited')"
                                class="oe_highlight"/>
                        <button name='returned_2_close' string='Close' type='object' 
                                 invisible="state != 'returned'" class="oe_highlight"/>
                        <button class="oe_highlight" name='under_collection_outstanding' string='Under Collection'
                                type='object' invisible="state != 'returned' and partner_type == 'supplier'"/>
                        <button class="oe_highlight" name='under_collection_outstanding' string='Outstanding'
                                type='object' invisible="state != 'returned' and partner_type == 'customer'" />
                        <field name="vendor_state" widget="statusbar" statusbar_visible="outstanding,paid,closed"
                                invisible="payment_type != 'outbound'"/>
                        <field name="customer_state" widget="statusbar"
                               statusbar_visible="under-collection,deposited,closed"
                               invisible="payment_type != 'inbound'"/>
                        <field name="state" invisible="1"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" type="action"
                                    name="%(check_managment.action_move_line_form)d" icon="fa-bars"
                                    string="journal Entry">
                            </button>
                        </div>
                        <group col='4'>

                            <field name="payment_id" readonly="1"/>
                            <field name="payment_type" invisible="1"/>
                            <field name="partner_id"/>
                            <field name="journal_id"/>
                            <field name="amount"/>
                            <field name='check_no'/>
                            <field name='beneficiary'/>
                            <field name="partner_type" invisible="1"/>

                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="action_account_checks_followup" model="ir.actions.act_window">
            <field name="name">Checks Followup</field>
            <field name="res_model">account.checks.followup</field>
            <field name="view_mode">list,form,pivot</field>
            <field name="view_id" ref="view_tree_account_checks_followup"/>
        </record>


        <record id="followup_view_search" model="ir.ui.view">
            <field name="name">followup checks search view</field>
            <field name="model">account.checks.followup</field>
            <field name="arch" type="xml">
                <search string="Search followup checks">
                    <field name="payment_id"/>
                    <field name="partner_id"/>
                    <field name="check_no"/>
                    <field name="journal_id"/>

                    <filter name="partner_id" string="partner" context="{'group_by':'partner_id'}"/>
                    <filter name="journal_id" string="journal" context="{'group_by':'journal_id'}"/>
                </search>
            </field>
        </record>

        <menuitem id="menu_account_checks_followup" parent="account.menu_finance_entries" name="Checks Followup"
                  action="action_account_checks_followup"/>
    </data>

</odoo>
