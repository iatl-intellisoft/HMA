<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="paperformat_check_printing_special" model="report.paperformat">
            <field name="name">Cheque Size Paper</field>
            <field name="default" eval="True"/>
            <field name="format">custom</field>
            <field name="page_height">170</field>
            <field name="page_width">85</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">0</field>
            <field name="margin_bottom">0</field>
            <field name="margin_left">0</field>
            <field name="margin_right">0</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">0</field>
            <field name="dpi">90</field>
        </record>

        <record id="paperformat_check_printing_a4" model="report.paperformat">
            <field name="name">A4 Cheque Paper</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">0</field>
            <field name="margin_bottom">0</field>
            <field name="margin_left">0</field>
            <field name="margin_right">0</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">0</field>
            <field name="dpi">90</field>
        </record>

    </data>
</odoo>
