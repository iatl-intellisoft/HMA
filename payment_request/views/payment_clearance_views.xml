<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record model="ir.ui.view" id="clearance_form_view">
            <field name="name">clearance.form</field>
            <field name="model">custody.clearance</field>
            <field name="arch" type="xml">
                <form string="Payment Clearance Form">
                    <header>
                        <button name="action_submit" type="object" string="Submit"
                                invisible="state != 'draft'" class="oe_highlight"/>
                        <!-- <button name="action_confirm" type="object" string="Confirm"
                                groups="payment_request.group_payment_request_manager"
                                invisible="state != 'submit'" class="oe_highlight"/> -->

                        <!-- <button name="action_approve" type="object" string="Approve"
                                groups="account.group_account_manager"
                                invisible="state != 'confirm'" class="oe_highlight"/> -->

                        <button name="action_done" type="object" string="Done"
                                invisible="1"
                                class="oe_highlight"/>
                        <button name="action_refuse" type="object" string="Refuse" invisible="state != 'finance_approval'" 
                                groups="account.group_account_manager" class="oe_highlight"/>
                        <button name="action_draft" type="object" string="Set to Draft" invisible="state != 'submit'" 
                                class="oe_highlight"/>
                        <button name="action_create_journal" groups="account.group_account_manager" type="object"
                                invisible="state != 'finance_approval' or move_id != False"
                                string="Create Journal Entries " class="oe_highlight"/>

                        <button name="%(payment_request.action_account_request_payment)d"
                                id="account_custody_payment_btn"
                                type="action"
                                invisible="state != 'finance_approval' or payment_amount == 0.0 or move_id == False"
                                string="Register Payment"
                                groups="account_custom.group_accountant_receivable" class="oe_highlight"/>
                        <field name="move_created" invisible="1"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <!-- <button class="oe_stat_button" type="action"
                                    name="%(payment_request.act_res_partner_3_custody)d"
                                    groups="account.group_account_user"
                                    icon="fa-usd"
                                    string="Clearance's Payments"
                                    invisible="payment_ids == False"/> -->

                            <field name="payment_ids" invisible="1"/>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="sequence"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="request_id" readonly="state != 'draft'"
                                       domain="[('state', 'in', ['paid']),('is_need_clearance', '=', True)]"/>                                       
                                <field name="employee_id" readonly="1"/>
                                <field name="partner_id" readonly="1"/>
                                <field name="creator" invisible="1"/>
                                <field name="department_id" invisible="1"/>
                                 <field name="custody_amount"/> 
                                <field name="request_remaining_amount"  readonly="1"/>
                                <field name="is_renewable" invisible="1" readonly="1"/>
                            </group>
                            <group>
                                <field name="date" readonly="state != 'draft'"/>
                                <field name="move_id" readonly="1" invisible="move_id == False"/> 
                                <field name="company_id" readonly="1"/>
                                <field name="account_id" readonly="1" invisible="1"/>
                                <field name="journal_id" domain="[('type','=','general')]"
                                       invisible="state != 'finance_approval'"
                                       required="state == 'finance_approval'"/>
                                       
                                <field name="vehicle_id"  readonly="state != 'draft'"
                                     />
                                <field name="driver_id" readonly="1"   /> 
                                <field name="payment_amount" readonly="1"
                                       invisible="is_renewable != False or move_id != True"/>
                               
                                <field name="total_amount" readonly="1"/>
                                <!-- <field name="currency_id"/> -->


                            </group>
                        </group>

                        <notebook>
                        <page string="Details" >
                                <field name="custody_line_ids" readonly="state != 'draft'">
                                    <list string="Clearance Details" editable="bottom">
                                        <field name="account_id" required="1"/>
                                        <field name="partner_id" required="1"/> 
                                        <field name="company_id" column_invisible="1"/>
                                        <field name="analytic_account_id" column_invisible="1"/>
                                        <!-- <field name="clearance_type" required="1"/>  -->
                                        <field name="desc" required="1"/>
                                        <field name="quantity" required="1"/> 
                                        <field name="price_unit" required="1" />
                                        <field name="amount" required="1"/>
                                        <field name="clearance_id" column_invisible="1"/> 
                                    </list>
                                </field>
                                <group class="oe_subtotal_footer oe_right">
                                    <field name="total_clearance" class="oe_subtotal_footer_separator"/>
                                </group>
                            </page>
                        
                            <!-- <page string="Documents Details">
                                <group>
                                    <field name="attachment_ids" widget="many2many_binary" readonly="state != 'draft'"/>
                                </group>
                            </page> -->



                        </notebook>
                    </sheet>
                    <chatter reload_on_follower="True"/>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="clearance_tree_view">
            <field name="name">clearance.tree</field>
            <field name="model">custody.clearance</field>
            <field name="arch" type="xml">
                <list string="Payment Clearance">
                    <field name="sequence"/>
                    <field name="date"/>
                    <field name="employee_id" />
                    <field name="vehicle_id" />
                    <field name="driver_id"  /> 
                    <field name="request_id"/>
                    <field name="total_amount"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="clearance_search_view">
            <field name="name">clearance.search</field>
            <field name="model">custody.clearance</field>
            <field name="arch" type="xml">
                <search string="clearance Search">
                    <field name="employee_id"/>
                    <field name="date"/>
                    <field name="request_id" string="Advance Claim"/>
                    <field name="state"/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_state" string="Status" context="{'group_by':'state'}"/>
                        <filter name="group_by_request_id" string="Advance Claim" context="{'group_by':'request_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="payment_clearance_action">
            <field name="name">Payment Clearance</field>
            <field name="res_model">custody.clearance</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>
