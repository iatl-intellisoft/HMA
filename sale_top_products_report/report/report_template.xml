<odoo>
    <template id="report_top_products_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2 class="text-center">تقرير أكثر المنتجات مبيعًا</h2>
                    <p class="text-center">
                        الفترة من <span t-esc="date_from"/> إلى <span t-esc="date_to"/>
                    </p>
                    <table class="table table-bordered table-sm" style="margin-top: 20px;">
                        <thead>
                            <tr style="background-color:#f2f2f2;">
                                <th class="text-center">الترتيب</th>
                                <!-- <th>كود المنتج</th> -->
                                <th>اسم المنتج</th>
                                <th class="text-center">الكمية المسلّمة</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="lines" t-as="line">
                                <td class="text-center" t-esc="line['rank']"/>
                                <!-- <td t-esc="line['product_code']"/> -->
                                <td t-esc="line['product_name']"/>
                                <td class="text-center" t-esc="line['total_qty']"/>
                            </tr>
                            <tr t-if="not lines">
                                <td colspan="4" class="text-center">لا يوجد بيانات في هذه الفترة</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
