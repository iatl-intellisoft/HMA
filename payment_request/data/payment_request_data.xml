<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="ir_cron_late_payment" model="ir.cron">
            <field name="name">Late Payment Cron</field>
            <field name="model_id" ref="payment_request.model_payment_request"/>
            <field name="type">ir.actions.server</field>
            <field name="state">code</field>
            <field name="code">model.call_link()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
<!--            <field name="numbercall">-1</field>-->
        </record>

        <record model="discuss.channel" id="channel_accountant_group">
            <field name="name">Accountant</field>
            <field name="group_ids" eval="[(4, ref('account.group_account_user'))]"/>
            <field name="description">Message Custody Notifications.</field>
        </record>


    </data>
</odoo>
