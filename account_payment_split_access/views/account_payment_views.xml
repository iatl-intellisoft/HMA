<odoo>
        <record id="account_payment_inherit" model="ir.ui.view">
            <field name="name">account.payment.inherit</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <field name="is_split_payment" invisible="1" />
                </xpath>

                <xpath expr="//field[@name='payment_type']" position="attributes">
                    <attribute name="readonly">is_split_payment</attribute>
                </xpath>

                <xpath expr="//field[@name='partner_type']" position="attributes">
                    <attribute name="readonly">is_split_payment</attribute>
                </xpath>

                <!-- <xpath expr="//field[@name='journal_id']" position="attributes">
                    <attribute name="readonly">is_split_payment</attribute>
                </xpath> -->
                 
            </field>
        </record>

    <!-- CUSTOMER CASH -->
    <record id="action_customer_cash" model="ir.actions.act_window">
        <field name="name">Customer Cash Payments</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form</field>

        <field name="domain">
            [('payment_type','=','inbound'),
             ('partner_type','=','customer'),
             ('journal_id.type','=','cash')]
        </field>

        <field name="context">
        {
            'payment_mode':'customer_cash',
            'default_payment_type':'inbound',
            'default_partner_type':'customer',
            'journal_type_filter':'cash'
        }
    </field>
    </record>


