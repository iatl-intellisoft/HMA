<?xml version="1.0" encoding="utf-8"?>
<odoo>
 
    <record id="view_tax_invoice_list" model="ir.ui.view">
        <field name="name">tax.invoice.list</field>
        <field name="model">tax.invoice</field>
        <field name="arch" type="xml">
            <list>
                <field name="reference"/>
                <field name="date"/>
                <field name="customer_id"/>
                <field name="total_amount"/>
                <field name="tax_amount"/>
                <field name="due_amount"/>
            </list>
        </field>
    </record>
 
    <record id="view_tax_invoice_form" model="ir.ui.view">
        <field name="name">tax.invoice.form</field>
        <field name="model">tax.invoice</field>
        <field name="arch" type="xml">
            <form string="Tax Invoice">
                <sheet>
                    <group>
                        <group>
                            <field name="reference"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="customer_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Product Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="label"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="tax"/>
                                    <field name="total_price" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                    <group>
                        <field name="total_amount" readonly="1"/>
                        <field name="tax_amount" readonly="1"/>
                        <field name="due_amount" readonly="1"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>
 
    <record id="action_tax_invoice" model="ir.actions.act_window">
        <field name="name">Taxes Invoices</field>
        <field name="res_model">tax.invoice</field>
        <field name="view_mode">list,form</field>
    </record>
 
    <menuitem id="menu_tax_invoice_root"
              name="Taxes Invoices"
              parent="account.menu_finance_receivables"
              action="action_tax_invoice"

              sequence="50"/>
 
    <record id="product_template_form_inherit" model="ir.ui.view">
        <field name="name">product.template.form.view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='standard_price']" position="after">
                <field name="tax_price"/>        
            </xpath>

        </field>
    </record>
</odoo>