<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_delivery_control" model="ir.ui.view">
        <field name="name">sale.order.form.delivery.control</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <div class="alert alert-warning" role="alert" invisible="state != 'pending_approval'">
                    <strong>بانتظار اعتماد المبيعات:</strong> هذا عميل "معتمد"، ولن يتم تأكيد
                    الأوردر فعلياً ولا إنشاء أمر توصيل له إلا بعد اعتماد مسؤول اعتماد المبيعات
                    المحدد في الإعدادات. تم إرسال إشعار له.
                    <br/>
                    <button name="action_approve_sales_order" type="object"
                            string="اعتماد الطلب" class="btn-primary mt-2"
                            invisible="not can_approve_order"/>
                    <button name="action_reject_sales_order" type="object"
                            string="رفض وإرجاع لمسودة" class="btn-secondary mt-2"
                            invisible="not can_approve_order"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
