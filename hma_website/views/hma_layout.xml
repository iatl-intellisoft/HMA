  <template id="hma_fonts" inherit_id="website.layout" name="HMA Fonts">
    <xpath expr="//head" position="inside">
      <link rel="preconnect" href="https://fonts.googleapis.com"/>
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
      <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&amp;display=swap" rel="stylesheet"/>
    </xpath>
  </template>

  <!-- Login, password-protected pages, etc. use website.login_layout → website.layout by default -->
  <template id="hma_login_layout" inherit_id="website.login_layout" name="HMA Website Login Layout" priority="25">
    <xpath expr="//t[@t-call='website.layout']" position="replace">
      <t t-call="hma_website.hma_website_layout">
        <div class="oe_website_login_container" t-out="0"/>
      </t>
    </xpath>
  </template>

  <template id="hma_website_layout" name="HMA Website Layout">
    <t t-call="website.layout">
      <!-- Always use HMA chrome; never swap to Odoo default header/footer on this layout. -->
      <t t-set="no_header" t-value="True"/>
      <t t-set="no_footer" t-value="True"/>
      <t t-set="body_classname" t-value="'hma-website'"/>
      <t t-set="pageName" t-value="'o_hma_website'"/>

      <t t-call="hma_website.hma_public_topbar"/>
      <t t-call="hma_website.hma_public_header"/>

      <div id="wrap" class="hma-website">
        <!-- Page snippet drop zone (hidden until Website Builder adds body.editor_enable) -->
        <div id="oe_structure_hma_editor" class="oe_structure oe_empty" data-name="Content"/>
        <t t-out="0"/>
      </div>

      <t t-call="hma_website.hma_public_footer"/>
    </t>
  </template>

</odoo>
