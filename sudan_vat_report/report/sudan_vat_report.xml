<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="paperformat_2" model="report.paperformat">
            <field name="name">Insurance</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">5</field>
            <field name="margin_bottom">5</field> 
            <field name="header_line" eval="False"/>
            <field name="dpi">96</field>
        </record> 
    <!-- Report Action -->
    <record id="action_report_sudan_vat" model="ir.actions.report">
        <field name="name">الإقرار الشهري للضريبة على القيمة المضافة</field>
        <field name="model">sudan.vat.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sudan_vat_report.report_sudan_vat_template</field>
        <field name="report_file">sudan_vat_report.report_sudan_vat_template</field>
        <field name="binding_model_id" ref="sudan_vat_report.model_sudan_vat_report"/> 

        <field name="paperformat_id" ref="sudan_vat_report.paperformat_2"/>
    </record> 

    
</odoo>
