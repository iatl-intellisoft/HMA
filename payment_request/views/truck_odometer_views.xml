<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record model="ir.ui.view" id="truck_odometer_form_view">
            <field name="name">truck.odometer.form</field>
            <field name="model">truck.odometer</field>
            <field name="arch" type="xml">
                <form string="Truck Odometer">
                 
                        <group>
                            <group>
                                <field name="truck_id"/>  
                                <field name="date"/>  
                                <field name="odometer"/>  
                                <field name="source"/>  
                                <field name="distance"/>  
                            </group> 
                        </group>
 
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="truck_odometer_tree_view">
            <field name="name">truck.odometer.tree</field>
            <field name="model">truck.odometer</field>
            <field name="arch" type="xml">
                <list string="Truck Odometer">
                    <field name="truck_id"/>  
                    <field name="date"/>  
                    <field name="odometer"/>  
                    <field name="source"/>  
                    <field name="distance"/>  
                </list>
            </field>
        </record> 

        <record model="ir.actions.act_window" id="truck_odometer_action">
            <field name="name">Truck Odometer</field>
            <field name="res_model">truck.odometer</field>
            <field name="view_mode">list,form</field>
        </record>
   <menuitem id="menu_truck_odometer_view"
                  name="Truck Odometer"
                  parent="menu_payment_request_root"
                  action="truck_odometer_action"
                />
    </data>
</odoo>