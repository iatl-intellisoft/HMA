<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Inherit Form View to Modify it HR Loan-->
        <record id="view_inherit_hr_loan_form" model="ir.ui.view">
            <field name="name">hr.loan.form</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//header/button[@name='action_approve']" position="before">
                    <button name="action_department_manager" class="oe_highlight" type="object" string="Approve" invisible="state != 'wait_department_manager'"
                    groups="hr_custom.group_hr_department_manager"/>
                    <button name="action_hr_manager" class="oe_highlight" type="object" string="Approve" invisible="state != 'wait_hr_manager'"
                    groups="hr.group_hr_manager"/>
                </xpath>

                <xpath expr="//field[@name='state']" position="replace">
                    <field name="state" widget="statusbar" statusbar_visible="confirm,wait_department_manager,wait_hr_manager,validate"/>
                </xpath>
            </field>
        </record>
                </data>
</odoo>