            <t t-foreach="featured_products" t-as="p">
              <div t-attf-class="prod-card #{p.dark_bg and 'dark-bg' or ''} fade-in">
                <div class="prod-icon-wrap">
                  <div t-attf-class="prod-icon-box #{p.category == 'chinbull' and 'cb' or (p.dark_bg and 'dark' or '')}">
