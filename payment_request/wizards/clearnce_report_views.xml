<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="clearnce_report_form_view" model="ir.ui.view">
            <field name="name">clearnce.report.form.view</field>
            <field name="model">clearnce.report</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <group>
                            <field name="start_date" required="1"/>
                        </group>
                        <group>
                            <field name="end_date" required="1"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_generate_clearnce_excel" type="object" string="Generate Report"
                                class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_clearnce_excel_report" model="ir.actions.act_window">
            <field name="name">clearnce Report</field>
            <field name="res_model">clearnce.report</field>
            <field name="target">new</field>
            <field name="view_id" ref="clearnce_report_form_view"/>
        </record>


