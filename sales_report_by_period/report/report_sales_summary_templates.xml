<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="report_sales_summary_document">
    <t t-call="web.html_container">
        <t t-set="company" t-value="docs and docs[0].company_id or env.company"/>
        <t t-call="web.basic_layout">
            <div class="page" dir="rtl" style="font-family: 'Amiri', 'Noto Naskh Arabic', Arial, sans-serif; font-size: 11px;">

                <!-- Company header -->
                <div style="text-align:center; border-bottom: 2px solid #900; padding-bottom:8px; margin-bottom:10px;">
                    <img t-if="company.logo" t-att-src="image_data_uri(company.logo)"
                         style="max-height:70px;"/>
                    <h3 style="margin:4px 0;" t-esc="company.name"/>
                </div>

                <h2 style="text-align:center; margin-bottom:2px;">تقرير مبيعات للأصناف حسب أمر البيع</h2>
                <p style="text-align:center; margin-top:0;">
                    من
                    <span t-esc="data.get('date_from')"/>
                    إلى
                    <span t-esc="data.get('date_to')"/>
                </p>

                <t t-set="grand_total" t-value="0.0"/>
                <t t-set="grand_paid" t-value="0.0"/>
                <t t-set="grand_returned" t-value="0.0"/>
                <t t-set="grand_remaining" t-value="0.0"/>

                <!-- ============ لف على أوامر البيع ============ -->
                <t t-foreach="orders_data" t-as="order_group">

                    <t t-set="order" t-value="order_group['order']"/>
                    <t t-set="order_moves" t-value="order_group['moves']"/>

                    <!-- رأس أمر البيع -->
                    <table style="width:100%; border-collapse:collapse; margin-top:14px;">
                        <tr style="background-color:#900; color:white; font-weight:bold;">
                            <td style="border:1px solid #900; padding:5px;" colspan="2">
                                أمر البيع:
                                <span t-if="order" t-esc="order.name"/>
                                <span t-else="">بدون أمر بيع مرتبط</span>
                            </td>
                            <td style="border:1px solid #900; padding:5px;">
                                تاريخ الأمر:
                                <span t-if="order" t-esc="order.date_order and order.date_order.date()"/>
                                <span t-else="">-</span>
                            </td>
                            <td style="border:1px solid #900; padding:5px;">
                                العميل:
                                <span t-esc="(order and order.partner_id.name) or (order_moves and order_moves[0].partner_id.name) or '-'"/>
                            </td>
                            <td style="border:1px solid #900; padding:5px;">
                                المندوب:
                                <span t-esc="(order and order.user_id.name) or (order_moves and order_moves[0].invoice_user_id.name) or 'المكتب'"/>
                            </td>
                            <td style="border:1px solid #900; padding:5px;">
                                إجمالي الأمر:
                                <span t-if="order" t-esc="'{:,.0f}'.format(order.amount_total)"/>
                                <span t-else="">-</span>
                            </td>
                        </tr>
                    </table>

                    <!-- الفواتير المرتبطة بهذا الأمر -->
                    <table style="width:100%; border-collapse:collapse;" t-foreach="order_moves" t-as="move">

                        <t t-set="is_refund" t-value="move.move_type == 'out_refund'"/>
                        <t t-set="amount" t-value="move.amount_total"/>
                        <t t-set="paid" t-value="move.amount_total - move.amount_residual"/>
                        <t t-set="remaining" t-value="move.amount_residual"/>
                        <t t-set="returned" t-value="amount if is_refund else 0.0"/>
                        <t t-set="shown_amount" t-value="0.0 if is_refund else amount"/>
                        <t t-set="shown_paid" t-value="0.0 if is_refund else paid"/>

                        <t t-set="grand_total" t-value="grand_total + shown_amount"/>
                        <t t-set="grand_paid" t-value="grand_paid + shown_paid"/>
                        <t t-set="grand_returned" t-value="grand_returned + returned"/>
                        <t t-set="grand_remaining" t-value="grand_remaining + remaining"/>

                        <!-- Invoice header row -->
                        <tr style="background-color:#e9e9e9; font-weight:bold;">
                            <td style="border:1px solid #999; padding:3px;">رقم الفاتورة<br/>
                                <span t-esc="move.name"/>
                            </td>
                            <td style="border:1px solid #999; padding:3px;">تاريخ الفاتورة<br/>
                                <span t-esc="move.invoice_date"/>
                            </td>
                            <td style="border:1px solid #999; padding:3px;">العميل<br/>
                                <span t-esc="move.partner_id.name"/>
                            </td>
                            <td style="border:1px solid #999; padding:3px;">المندوب<br/>
                                <span t-esc="move.invoice_user_id.name or 'المكتب'"/>
                            </td>
                            <td style="border:1px solid #999; padding:3px;">المبلغ<br/>
                                <span t-esc="'{:,.0f}'.format(shown_amount)"/>
                            </td>
                            <td style="border:1px solid #999; padding:3px;">المدفوع<br/>
                                <span t-esc="'{:,.0f}'.format(shown_paid)"/>
                            </td>
                            <td style="border:1px solid #999; padding:3px;">المردود<br/>
                                <span t-esc="'{:,.0f}'.format(returned)"/>
                            </td>
                            <td style="border:1px solid #999; padding:3px;">المتبقي<br/>
                                <span t-esc="'{:,.0f}'.format(remaining)"/>
                            </td>
                        </tr>

                        <!-- Line items sub-header -->
                        <tr style="background-color:#f5f5f5; font-size:10px;">
                            <td style="border:1px solid #ccc; padding:2px;" colspan="2">رقم الصنف</td>
                            <td style="border:1px solid #ccc; padding:2px;" colspan="2">إسم الصنف</td>
                            <td style="border:1px solid #ccc; padding:2px;">الوحدة</td>
                            <td style="border:1px solid #ccc; padding:2px;">السعر</td>
                            <td style="border:1px solid #ccc; padding:2px;">الكمية</td>
                            <td style="border:1px solid #ccc; padding:2px;" colspan="2">المجموع</td>
                        </tr>

                        <t t-set="order_lines"
                           t-value="move.invoice_line_ids.filtered(lambda l: l.display_type in (False, 'product'))"/>

                        <tr t-if="not order_lines">
                            <td colspan="9" style="border:1px solid #ccc; padding:4px; text-align:center; color:#900;">
                                لا توجد أصناف مرتبطة بهذه الفاتورة
                            </td>
                        </tr>

                        <tr t-foreach="order_lines" t-as="line"
                            style="font-size:10px;">
                            <td style="border:1px solid #ccc; padding:2px;" colspan="2" t-esc="line.product_id.default_code or ''"/>
                            <td style="border:1px solid #ccc; padding:2px;" colspan="2" t-esc="line.name"/>
                            <td style="border:1px solid #ccc; padding:2px;" t-esc="line.product_uom_id.name or ''"/>
                            <td style="border:1px solid #ccc; padding:2px;" t-esc="'{:,.0f}'.format(line.price_unit)"/>
                            <td style="border:1px solid #ccc; padding:2px;" t-esc="'{:,.2f}'.format(line.quantity)"/>
                            <td style="border:1px solid #ccc; padding:2px;" colspan="2"
                                t-esc="'{:,.2f}'.format(line.price_subtotal)"/>
                        </tr>

                        <!-- spacer row -->
                        <tr>
                            <td colspan="9" style="height:6px; border:none;"/>
                        </tr>
                    </table>

                </t>
                <!-- ============ نهاية اللف على أوامر البيع ============ -->

                <!-- Grand total -->
                <table style="width:100%; border-collapse:collapse; margin-top:10px;">
                    <tr style="background-color:#900; color:white; font-weight:bold;">
                        <td style="border:1px solid #900; padding:5px;">الإجمالي العام</td>
                        <td style="border:1px solid #900; padding:5px;"
                            t-esc="'{:,.0f}'.format(grand_total)"/>
                        <td style="border:1px solid #900; padding:5px;"
                            t-esc="'{:,.0f}'.format(grand_paid)"/>
                        <td style="border:1px solid #900; padding:5px;"
                            t-esc="'{:,.0f}'.format(grand_returned)"/>
                        <td style="border:1px solid #900; padding:5px;"
                            t-esc="'{:,.0f}'.format(grand_remaining)"/>
                    </tr>
                    <tr style="font-size:10px;">
                        <td>الإجمالي</td>
                        <td>المبلغ</td>
                        <td>المدفوع</td>
                        <td>المردود</td>
                        <td>المتبقي</td>
                    </tr>
                </table>

            </div>
        </t>
    </t>
</template>

</odoo>
