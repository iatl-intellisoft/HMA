<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_sale_approval" model="ir.ui.view">
        <field name="name">sale.order.form.sale.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- زر اعتماد الطلب: يظهر فقط لمسؤول اعتماد المبيعات وعندما يكون الطلب بانتظار الاعتماد -->
            <xpath expr="//button[@name='action_confirm']" position="after">
                <button name="action_approve_sale_order"
                        string="اعتماد الطلب"
                        type="object"
                        class="btn-primary"
                        groups="custom_sale_approval.group_sales_approval_manager"
                        invisible="approval_state != 'to_approve'"/>
                <button name="action_reject_sale_order"
                        string="رفض الاعتماد"
                        type="object"
                        class="btn-secondary"
                        groups="custom_sale_approval.group_sales_approval_manager"
                        invisible="approval_state != 'to_approve'"/>
            </xpath>

            <!-- شريط حالة الاعتماد -->
            <xpath expr="//field[@name='state']" position="before">
                <field name="approval_state"
                       widget="statusbar"
                       invisible="approval_state == 'no'"
                       statusbar_visible="to_approve,approved"/>
            </xpath>

            <!-- معلومات الاعتماد داخل تبويب "معلومات إضافية" -->
            <xpath expr="//page[@name='other_information']" position="inside">
                <group string="اعتماد المبيعات"
                       invisible="approval_state == 'no'">
                    <field name="approval_state" readonly="1"/>
                    <field name="approval_user_id" readonly="1"/>
                    <field name="approval_date" readonly="1"/>
                </group>
            </xpath>

        </field>
    </record>

    <!-- إضافة فلتر بحث سريع للطلبات بانتظار الاعتماد -->
    <record id="view_sales_order_filter_approval" model="ir.ui.view">
        <field name="name">sale.order.search.approval</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <filter string="بانتظار الاعتماد"
                        name="filter_waiting_approval"
                        domain="[('approval_state', '=', 'to_approve')]"/>
            </xpath>
        </field>
    </record>
</odoo>
