<?xml version="1.0" encoding="utf-8"?>
<odoo>
 
   
<data> 

    <template id="report_sale_delivery_document">

       <t t-call="web.external_layout">            
            <head>  
                    <style>

                        .title{
                            text-align:center;
                            font-size:24px;
                            font-weight:bold;
                            margin-bottom:20px;
                        }

                        .sub-title{
                            text-align:center;
                            font-size:13px;
                            color:#666;
                            margin-bottom:25px;
                        }

                        .info{
                            width:100%;
                            border-collapse:collapse;
                            margin-bottom:25px;
                        }

                        .info td{
                            border:1px solid #444;
                            padding:8px;
                            font-size:13px;
                        }

                        .products{
                            width:100%;
                            border-collapse:collapse;
                        }

                        .products th{
                            background:#e8e8e8;
                            border:1px solid #000;
                            padding:8px;
                            text-align:center;
                            font-size:13px;
                        }

                        .products td{
                            border:1px solid #000;
                            padding:7px;
                            font-size:12px;
                        }

                        .center{
                            text-align:center;
                        }

                        .right{
                            text-align:right;
                        }

                        .footer-sign{
                            margin-top:60px;
                            width:100%;
                        }

                        .footer-sign td{
                            width:33%;
                            text-align:center;
                            padding-top:50px;
                        }

                    </style>
 
 <meta charset="UTF-8"/>                     
            </head>  
 <div class="title"> 
                        إذن إستلام
                    </div>
            <t t-foreach="docs" t-as="o">
            <main class="page"  >

                    <table class="info">

                        <tr>

                            <td>
                                <strong>رقم الطلب</strong>
                            </td>

                            <td>
                                <span t-field="o.sale_id.name"/> 
                            </td>

                            <td>
                                <strong>التاريخ</strong>
                            </td>

                            <td>
                                <span t-field="o.scheduled_date"
                                      t-options='{"widget":"date"}'/>
                            </td>

                        </tr>

                        <tr>

                            <td>
                                <strong>العميل</strong>
                            </td>

                            <td> 
                             <span t-field="o.sale_id.partner_id.name"/> 
                            </td>

                            <td>
                                <strong>الرقم الوطني للعميل</strong>
                            </td>

                            <td> 
                             <span t-field="o.sale_id.partner_id.national_id"/> 
                            </td>

                        </tr>

                        <tr>
                            <td>
                                <strong>المعرف الضريبي للعميل</strong>
                            </td>

                            <td> 
                             <span t-field="o.sale_id.partner_id.vat"/> 
                            </td> 

                            <td>
                                <strong>مكتب الشحن</strong>
                            </td>

                            <td> 
                             <span t-field="o.shipping_office_name"/> 
                            </td>

                 
                        </tr>
                     <tr>
                           <td>
                                <strong>رقم المكتب</strong>
                            </td>

                            <td> 
                             <span t-field="o.shipping_office_number"/>
                            </td>
                           <td>
                                <strong>مكان إرسال البضاعة</strong>
                            </td>

                            <td> 
                             <span t-field="o.shipping_destination"/> 
                            </td>
 

                        </tr>
                        <t t-set="total_qty"
                         t-value="sum(
                             line.quantity
                             for line in o.move_ids_without_package
                             if line.product_id.type != 'service'
                         )"/>
                       <tr>
                           <td>
                                <strong>إجمالي الكميات</strong>                            
                           </td>
                           <td>
                               <t t-esc="total_qty"/>
                           </td>
                       </tr>

                    </table>

                    <table class="products">

                        <thead>

                            <tr>

                                <th style="width:6%">#</th>

                                <th>
                                    المنتج
                                </th>

                                <th style="width:15%">
                                    الكمية
                                </th>

                                <th style="width:15%">
                                    الوحدة
                                </th>

                                <th style="width:25%"> 
                                    المخزن
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            <t t-set="i" t-value="1"/>

                            <t t-foreach="o.move_ids_without_package.filtered(lambda m: m.state != 'cancel')" t-as="move">

                                <tr>

                                    <td class="center">
                                        <span t-esc="i"/>
                                        <t t-set="i" t-value="i+1"/>
                                    </td>

                                    <td>
                                        <span t-field="move.product_id"/>
                                    </td>

                                    <td class="center">
                                        <span t-field="move.quantity"/>
                                    </td>

                                    <td class="center">
                                        <span t-field="move.product_uom"/>
                                    </td>

                                    <td>
                                        <span t-field="move.location_id"/>
                                    </td>

                                </tr>

                            </t>

                        </tbody>

                    </table>

                    
  
</main>
            </t>

        </t>

    </template>
 
       <record id="action_report_sale_delivery" model="ir.actions.report">
        <field name="name">Delivery</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">delivery_order_report.report_sale_delivery_document</field>
        <field name="report_file">delivery_order_report.report_sale_delivery_document</field>
        <field name="print_report_name">'Delivery - %s' % (object.name)</field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
    </record>
</data>
</odoo>
