<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <template id="report_custody_clearance">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <div>
                            <h2 style='text-align: center;'>Custody Clearance</h2>
                            <br/>
                            <h3>Payment Clearance
                                <span t-field="o.request_id.name"/>
                            </h3>
                            <table class="table" style="border: 2px solid black">
                                <tbody>

                                    <tr>
                                        <td>
                                            <strong>Partner</strong>
                                        </td>
                                        <td>
                                            <span t-esc="o.partner_id.name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Employee</strong>
                                        </td>
                                        <td>
                                            <span t-esc="o.employee_id.name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Department</strong>
                                        </td>
                                        <td>
                                            <span t-esc="o.department_id.name"/>
                                        </td>

                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Currency</strong>
                                        </td>
                                        <td>
                                            <span t-esc="o.currency_id.name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Date</strong>
                                        </td>
                                        <td>
                                            <span t-esc="o.date"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Company</strong>
                                        </td>
                                        <td>
                                            <span t-esc="o.company_id.name"/>
                                        </td>
                                    </tr>
                                  <tr>
                                        <td>
                                            <strong>Custody Amount</strong>
                                        </td>
                                        <td>
                                            <span t-esc="o.custody_amount"/>
                                        </td>
                                    </tr>
                                  <tr>
                                        <td>
                                            <strong>Total Amount</strong>
                                        </td>
                                        <td>
                                            <span t-esc="o.total_amount"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Move</strong>
                                        </td>
                                        <td>
                                            <span t-esc="o.move_id.name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Payment Amount</strong>
                                        </td>
                                        <td>
                                            <span t-esc="o.payment_amount"/>
                                        </td>
                                    </tr>

                                </tbody>
                            </table>


                            <div t-if="len(o.custody_line_ids) &gt; 0">
                                <h3>Lines</h3>
                                <br/>
                                <table class="table table-bordered mt32">
                                    <thead>
                                        <tr>
                                            <th style="border: 2px solid black">
                                                <strong>Account</strong>
                                            </th>
                                            <th style="border: 2px solid black">
                                                <strong>Cost Centre</strong>
                                            </th>
                                            <th style="border: 2px solid black">
                                                <strong>Description</strong>
                                            </th>

                                            <th style="border: 2px solid black">
                                                <strong>Amount</strong>
                                            </th>


                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="o.custody_line_ids" t-as="custody_line_id">
                                            <td style="border: 2px solid black">
                                                <span t-esc="custody_line_id.desc"/>
                                            </td>
                                            <td style="border: 2px solid black">
                                                <span t-esc="custody_line_id.analytic_account_id.name"/>
                                            </td>
                                            <td style="border: 2px solid black">
                                                <span t-esc="custody_line_id.account_id.name"/>
                                            </td>
                                            <td style="border: 2px solid black">
                                                <span t-esc="custody_line_id.amount"/>
                                            </td>

                                        </tr>
                                        <tr>
                                            <td style="border: 2px solid black"/>
                                            <td style="border: 2px solid black"/>
                                            <td style="border: 2px solid black">
                                                <strong>Total</strong>
                                            </td>
                                            <td style="border: 2px solid black">
                                                <span t-esc="o.total_amount"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>

        <record id="action_report_custody_clearance" model="ir.actions.report">
            <field name="name">Custody Clearance</field>
            <field name="model">custody.clearance</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">payment_request.report_custody_clearance</field>
            <field name="binding_model_id" ref="payment_request.model_custody_clearance"/>
        </record>
    </data>
</odoo>