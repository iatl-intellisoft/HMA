<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cron_download_attendance_daily" model="ir.cron">
        <field name="name">Download Hikvision Attendance Daily</field>
        <field name="model_id" ref="model_hikvision_device"/>
        <field name="state">code</field>
        <field name="code">model.cron_download_attendance_all_devices()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).replace(hour=23, minute=55, second=58)"/>
    </record>

    <record id="ir_cron_send_attendance_notifications" model="ir.cron">
        <field name="name">Send Attendance Approval Notifications</field>
        <field name="model_id" ref="hikvision_odoo_integration.model_attendance_approval"/>
        <field name="state">code</field>
        <field name="code">model._cron_send_notifications()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).replace(hour=23, minute=58, second=10)"/>
    </record>


</odoo>