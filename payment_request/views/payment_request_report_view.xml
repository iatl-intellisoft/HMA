            </t>

            </t>

            </tbody>

            </table>

            </t>

            </t>
            </template>
        <record id="action_report_payment_request" model="ir.actions.report">
            <field name="name">Payment Request</field>
            <field name="model">payment.request</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">payment_request.report_custody_pdf</field>
            <field name="binding_model_id" ref="payment_request.model_payment_request"/>
        </record>
    </data>
</odoo>