<odoo>
    <record id="view_product_form_exchange" model="ir.ui.view">
        <field name="name">product.form.exchange</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Exchange Effect">
                    <group>
                        <field name="previous_cost"/> 
                        <field name="old_exchange_rate"/>
                        <field name="new_exchange_rate"/>
                        <field name="exchange_change_percent" readonly="1"/>
                    </group>

                    <group>
                        <field name="profit_margin"/>
                        <field name="new_cost" readonly="1"/>
                        <field name="new_sale_price" readonly="1"/>
                    </group>

                    <button name="action_apply_exchange_update"
                            type="object"
                            string="Apply New Cost and Price"
                            class="btn-primary"/>
                </page>
            </xpath>
        </field>
    </record>

</odoo>